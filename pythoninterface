# Попытка импорта звука (опционально)
try:
    import pygame
    pygame.mixer.init()
    SOUND_ENABLED = True
except ImportError:
    SOUND_ENABLED = False

class SoundManager:
    def __init__(self):
        self.enabled = SOUND_ENABLED
    def play(self, sound_name):
        if self.enabled:
            print(f"[Звук] {sound_name}")
    def toggle(self):
        self.enabled = not self.enabled
        return self.enabled

class AdaptiveButton(tk.Button):
    def __init__(self, master, text, command, bg='#FF6B6B', fg='white', **kwargs):
        super().__init__(master, text=text, command=command, bg=bg, fg=fg,
                        relief='raised', font=('Arial', 10, 'bold'))
        self.default_bg = bg
        self.hover_bg = self._lighten_color(bg)
        self.bind("<Enter>", self.on_enter)
        self.bind("<Leave>", self.on_leave)
        self.configure(width=20, height=2)
    
    def _lighten_color(self, color):
        try:
            r = int(color[1:3], 16)
            g = int(color[3:5], 16)
            b = int(color[5:7], 16)
            r = min(255, int(r * 1.2))
            g = min(255, int(g * 1.2))
            b = min(255, int(b * 1.2))
            return f'#{r:02x}{g:02x}{b:02x}'
        except:
            return '#FF8787'
    
    def on_enter(self, e):
        self.config(bg=self.hover_bg)
    
    def on_leave(self, e):
        self.config(bg=self.default_bg)

class InteractiveCookingGame:
    """Интерактивная мини-игра приготовления с разными механиками (замедленные анимации)"""
    def __init__(self, parent, action, on_complete):
        self.parent = parent
        self.action = action
        self.on_complete = on_complete
        self.progress = 0
        self.score = 0
        self.combo = 0
        self.timer_active = True
        
    def create_game(self, container):
        """Создает игровой интерфейс в зависимости от типа действия"""
        self.container = container
        self.clear_container()
        
        # Определяем тип мини-игры
        if "тесто" in self.action.lower() or "замесить" in self.action.lower():
            self.create_dough_game()
        elif "пасту" in self.action.lower() or "сварить" in self.action.lower():
            self.create_pasta_game()
        elif "крем" in self.action.lower() or "взбить" in self.action.lower():
            self.create_whip_game()
        elif "тушить" in self.action.lower() or "соус" in self.action.lower():
            self.create_stew_game()
        elif "рис" in self.action.lower():
            self.create_rice_game()
        elif "нарезать" in self.action.lower():
            self.create_chopping_game()
        else:
            self.create_click_game()
    
    def clear_container(self):
        for widget in self.container.winfo_children():
            widget.destroy()
    
    def create_dough_game(self):
        """Игра замеса теста - нужно вращать (двигать мышью) - ЗАМЕДЛЕНА"""
        tk.Label(self.container, text="🥣 ЗАМЕСИТЬ ТЕСТО", 
                font=('Arial', 16, 'bold'), bg='#FFF8E7', fg='#FF6B6B').pack(pady=10)
        
        self.dough_canvas = tk.Canvas(self.container, width=300, height=200, bg='#FFE5B4', relief='ridge')
        self.dough_canvas.pack(pady=20)
        
        # Рисуем миску с тестом
        self.dough_canvas.create_oval(50, 100, 250, 180, fill='#F5DEB3', outline='#8B4513', width=3)
        self.dough_canvas.create_text(150, 140, text="🥄", font=('Arial', 40))
        
        self.rotate_count = 0
        self.rotate_target = 15  # Увеличено с 10 до 15 для большего времени игры
        self.rotate_label = tk.Label(self.container, text=f"Вращений: 0/{self.rotate_target}", 
                                     font=('Arial', 12), bg='#FFF8E7')
        self.rotate_label.pack()
        
        # Счетчик для замедления (нужно больше движений)
        self.last_x, self.last_y = 0, 0
        self.move_distance = 0
        
        # Привязываем движение мыши
        self.dough_canvas.bind('<Motion>', self.on_dough_move)
        
        instruction = tk.Label(self.container, text="🖱️ Водите мышью по тесту, чтобы замесить!\n(Нужно больше движений)", 
                              font=('Arial', 10), bg='#FFF8E7', fg='gray')
        instruction.pack(pady=10)
    
    def on_dough_move(self, event):
        x, y = event.x, event.y
        # Проверяем, находится ли курсор в области миски
        if 50 < x < 250 and 100 < y < 180:
            # Вычисляем расстояние движения для более плавного прогресса
            if self.last_x != 0 and self.last_y != 0:
                dist = ((x - self.last_x) ** 2 + (y - self.last_y) ** 2) ** 0.5
                self.move_distance += dist
                
                # Накопление прогресса от расстояния (замедленно)
                if self.move_distance >= 30:  # Увеличено с 20 до 30
                    self.rotate_count += 1
                    self.move_distance = 0
                    self.rotate_label.config(text=f"Вращений: {self.rotate_count}/{self.rotate_target}")
                    self.progress = int(self.rotate_count / self.rotate_target * 100)
                    
                    # Анимация перемешивания
                    self.dough_canvas.delete('spoon')
                    spoon = self.dough_canvas.create_text(x, y, text="🥄", font=('Arial', 30), tags='spoon')
                    self.dough_canvas.after(150, lambda: self.dough_canvas.delete('spoon'))
            
            self.last_x, self.last_y = x, y
            
            if self.rotate_count >= self.rotate_target:
                self.dough_canvas.unbind('<Motion>')
                self.complete_game()
    
    def create_pasta_game(self):
        """Игра варки пасты - нужно поддерживать температуру (замедленный таймер)"""
        tk.Label(self.container, text="🍝 СВАРИТЬ ПАСТУ", 
                font=('Arial', 16, 'bold'), bg='#FFF8E7', fg='#FF6B6B').pack(pady=10)
        
        # Температура
        self.temp = 0
        self.target_temp = 100
        self.time_left = 45  # Увеличено с 30 до 45 секунд
        
        # Термометр
        self.temp_canvas = tk.Canvas(self.container, width=200, height=200, bg='white')
        self.temp_canvas.pack(pady=10)
        self.update_thermometer()
        
        # Кнопки управления
        btn_frame = tk.Frame(self.container, bg='#FFF8E7')
        btn_frame.pack(pady=10)
        
        self.heat_btn = tk.Button(btn_frame, text="🔥 +", command=lambda: self.change_temp(5),  # Уменьшено с 10 до 5
                                 bg='#F44336', fg='white', font=('Arial', 14), width=5)
        self.heat_btn.pack(side='left', padx=10)
        self.cool_btn = tk.Button(btn_frame, text="❄️ -", command=lambda: self.change_temp(-5),  # Уменьшено с 10 до 5
                                 bg='#2196F3', fg='white', font=('Arial', 14), width=5)
        self.cool_btn.pack(side='left', padx=10)
        
        self.temp_label = tk.Label(self.container, text=f"Температура: {self.temp}°C / {self.target_temp}°C", 
                                   font=('Arial', 12), bg='#FFF8E7')
        self.temp_label.pack()
        
        self.time_label = tk.Label(self.container, text=f"Осталось: {self.time_left} сек", 
                                   font=('Arial', 12), bg='#FFF8E7')
        self.time_label.pack()
        
        self.progress_bar = ttk.Progressbar(self.container, length=300, mode='determinate', maximum=100)
        self.progress_bar.pack(pady=10)
        
        self.timer = self.parent.after(1000, self.update_timer)
    
    def update_thermometer(self):
        self.temp_canvas.delete('all')
        # Рисуем термометр
        self.temp_canvas.create_rectangle(80, 180, 120, 20, fill='#E0E0E0')
        height = 160 * (self.temp / 100)
        self.temp_canvas.create_rectangle(80, 180 - height, 120, 180, fill='#F44336')
        self.temp_canvas.create_oval(70, 180, 130, 210, fill='#F44336')
        self.temp_canvas.create_text(100, 10, text=f"{self.temp}°C", font=('Arial', 10))
    
    def change_temp(self, delta):
        self.temp = max(0, min(100, self.temp + delta))
        self.update_thermometer()
        self.temp_label.config(text=f"Температура: {self.temp}°C / {self.target_temp}°C")
        
        # Проверка идеальной температуры
        if 90 <= self.temp <= 100:
            self.progress = min(100, self.progress + 3)  # Медленное накопление
            self.progress_bar['value'] = self.progress
            if self.progress >= 100:
                self.complete_game()
    
    def update_timer(self):
        if not self.timer_active:
            return
        self.time_left -= 1
        self.time_label.config(text=f"Осталось: {self.time_left} сек")
        if self.time_left > 0:
            self.timer = self.parent.after(1000, self.update_timer)
        else:
            # Время вышло - проверяем прогресс
            if self.progress >= 100:
                self.complete_game()
            else:
                messagebox.showinfo("Время вышло!", "Нужно быстрее поддерживать температуру!")
    
