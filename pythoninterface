                                             maximum=self.click_target)
        self.click_progress.pack(pady=10)
    
    def click_action(self):
        self.click_count += 1
        self.click_label.config(text=f"Нажатий: {self.click_count}/{self.click_target}")
        self.click_progress['value'] = self.click_count
        
        # Анимация кнопки
        self.click_btn.config(relief='sunken')
        self.parent.after(100, lambda: self.click_btn.config(relief='raised'))
        
        if self.click_count >= self.click_target:
            self.complete_game()
    
    def complete_game(self):
        """Завершение игры"""
        self.timer_active = False
        if hasattr(self, 'timer'):
            try:
                self.parent.after_cancel(self.timer)
            except:
                pass
        if hasattr(self, 'combo_timer'):
            try:
                self.parent.after_cancel(self.combo_timer)
            except:
                pass
        
        # Показываем сообщение о завершении
        messagebox.showinfo("Готово!", "Отлично! Блюдо приготовлено идеально! ✨")
        self.on_complete()
    """Интерактивная мини-игра приготовления с разными механиками"""
    def __init__(self, parent, action, on_complete):
        self.parent = parent
        self.action = action
        self.on_complete = on_complete
        self.progress = 0
        self.score = 0
        self.combo = 0
        
    def create_game(self, container):
        """Создает игровой интерфейс в зависимости от типа действия"""
        self.container = container
        self.clear_container()
        
        # Определяем тип мини-игры
        if "тесто" in self.action.lower() or "замесить" in self.action.lower():
            self.create_dough_game()
        elif "пасту" in self.action.lower() or "сварить" in self.action.lower():
            self.create_pasta_game()
        elif "крем" in self.action.lower() or "взбить" in self.action.lower():
            self.create_whip_game()
        elif "тушить" in self.action.lower() or "соус" in self.action.lower():
            self.create_stew_game()
        elif "рис" in self.action.lower():
            self.create_rice_game()
        elif "нарезать" in self.action.lower():
            self.create_chopping_game()
        else:
            self.create_click_game()
    
    def clear_container(self):
        for widget in self.container.winfo_children():
            widget.destroy()
    
    def create_dough_game(self):
        """Игра замеса теста - нужно вращать (двигать мышью)"""
        tk.Label(self.container, text="🥣 ЗАМЕСИТЬ ТЕСТО", 
                font=('Arial', 16, 'bold'), bg='#FFF8E7', fg='#FF6B6B').pack(pady=10)
        
        self.dough_canvas = tk.Canvas(self.container, width=300, height=200, bg='#FFE5B4', relief='ridge')
        self.dough_canvas.pack(pady=20)
        
        # Рисуем миску с тестом
        self.dough_canvas.create_oval(50, 100, 250, 180, fill='#F5DEB3', outline='#8B4513', width=3)
        self.dough_canvas.create_text(150, 140, text="🥄", font=('Arial', 40))
        
        self.rotate_count = 0
        self.rotate_label = tk.Label(self.container, text=f"Вращений: 0/10", 
                                     font=('Arial', 12), bg='#FFF8E7')
        self.rotate_label.pack()
        
        # Привязываем движение мыши
        self.dough_canvas.bind('<Motion>', self.on_dough_move)
        
        instruction = tk.Label(self.container, text="🖱️ Водите мышью по тесту, чтобы замесить!", 
                              font=('Arial', 10), bg='#FFF8E7', fg='gray')
        instruction.pack(pady=10)
    
    def on_dough_move(self, event):
        x, y = event.x, event.y
        # Проверяем, находится ли курсор в области миски
        if 50 < x < 250 and 100 < y < 180:
            self.rotate_count += 1
            self.rotate_label.config(text=f"Вращений: {self.rotate_count}/10")
            self.progress = min(100, self.rotate_count * 10)
            
            # Анимация перемешивания
            self.dough_canvas.delete('spoon')
            self.dough_canvas.create_text(x, y, text="🥄", font=('Arial', 30), tags='spoon')
            
            if self.rotate_count >= 10:
                self.dough_canvas.unbind('<Motion>')
                self.on_complete()
    
    def create_pasta_game(self):
        """Игра варки пасты - нужно поддерживать температуру"""
        tk.Label(self.container, text="🍝 СВАРИТЬ ПАСТУ", 
                font=('Arial', 16, 'bold'), bg='#FFF8E7', fg='#FF6B6B').pack(pady=10)
        
        # Температура
        self.temp = 0
        self.target_temp = 100
        self.time_left = 30
        
        # Термометр
        self.temp_canvas = tk.Canvas(self.container, width=200, height=200, bg='white')
        self.temp_canvas.pack(pady=10)
        self.update_thermometer()
        
        # Кнопки управления
        btn_frame = tk.Frame(self.container, bg='#FFF8E7')
        btn_frame.pack(pady=10)
        
        tk.Button(btn_frame, text="🔥 +", command=lambda: self.change_temp(10),
                 bg='#F44336', fg='white', font=('Arial', 14), width=5).pack(side='left', padx=10)
        tk.Button(btn_frame, text="❄️ -", command=lambda: self.change_temp(-10),
                 bg='#2196F3', fg='white', font=('Arial', 14), width=5).pack(side='left', padx=10)
        
        self.temp_label = tk.Label(self.container, text=f"Температура: {self.temp}°C / {self.target_temp}°C", 
                                   font=('Arial', 12), bg='#FFF8E7')
        self.temp_label.pack()
        
        self.time_label = tk.Label(self.container, text=f"Осталось: {self.time_left} сек", 
                                   font=('Arial', 12), bg='#FFF8E7')
        self.time_label.pack()
        
        self.timer = self.parent.after(1000, self.update_timer)
    
    def update_thermometer(self):
        self.temp_canvas.delete('all')
        # Рисуем термометр
        self.temp_canvas.create_rectangle(80, 180, 120, 20, fill='#E0E0E0')
        height = 160 * (self.temp / 100)
        self.temp_canvas.create_rectangle(80, 180 - height, 120, 180, fill='#F44336')
        self.temp_canvas.create_oval(70, 180, 130, 210, fill='#F44336')
        self.temp_canvas.create_text(100, 10, text=f"{self.temp}°C", font=('Arial', 10))
    
    def change_temp(self, delta):
        self.temp = max(0, min(100, self.temp + delta))
        self.update_thermometer()
        self.temp_label.config(text=f"Температура: {self.temp}°C / {self.target_temp}°C")
        
        # Проверка идеальной температуры
        if 90 <= self.temp <= 100:
            self.progress += 5
            if self.progress >= 100:
                self.complete_game()
    
    def update_timer(self):
        self.time_left -= 1
        self.time_label.config(text=f"Осталось: {self.time_left} сек")
        if self.time_left > 0:
            self.timer = self.parent.after(1000, self.update_timer)
        else:
            self.complete_game()
    
    def create_whip_game(self):
        """Игра взбивания - нужно кликать с определенной скоростью"""
        tk.Label(self.container, text="🥣 ВЗБИТЬ КРЕМ", 
                font=('Arial', 16, 'bold'), bg='#FFF8E7', fg='#FF6B6B').pack(pady=10)
        
        self.whip_count = 0
        self.whip_target = 20
        
        # Анимированная миска
        self.whip_canvas = tk.Canvas(self.container, width=250, height=200, bg='#FFE5B4')
        self.whip_canvas.pack(pady=10)
        self.whip_canvas.create_oval(50, 80, 200, 160, fill='#F5DEB3')
        self.whip_text = self.whip_canvas.create_text(125, 120, text="🥄", font=('Arial', 50))
        
        self.whip_btn = tk.Button(self.container, text="👋 ВЗБИВАЙ!", command=self.whip_action,
                                  bg='#FF6B6B', fg='white', font=('Arial', 14), width=20, height=2)
        self.whip_btn.pack(pady=10)
        
        self.whip_label = tk.Label(self.container, text=f"Взбиваний: 0/{self.whip_target}", 
                                   font=('Arial', 12), bg='#FFF8E7')
        self.whip_label.pack()
        
        self.combo_label = tk.Label(self.container, text="", font=('Arial', 10), bg='#FFF8E7', fg='gold')
        self.combo_label.pack()
    
    def whip_action(self):
        self.whip_count += 1
        self.combo += 1
        
        # Анимация взбивания
        self.whip_canvas.coords(self.whip_text, 125 + random.randint(-10, 10), 
                                120 + random.randint(-10, 10))
        self.whip_canvas.after(50, lambda: self.whip_canvas.coords(self.whip_text, 125, 120))
        
        self.whip_label.config(text=f"Взбиваний: {self.whip_count}/{self.whip_target}")
        self.progress = int(self.whip_count / self.whip_target * 100)
        
        if self.combo >= 3:
            self.combo_label.config(text=f"🔥 КОМБО x{self.combo}! 🔥")
            # Бонусный прогресс за комбо
            self.whip_count += 1
            self.whip_label.config(text=f"Взбиваний: {self.whip_count}/{self.whip_target}")
        
        if self.whip_count >= self.whip_target:
            self.complete_game()
    
    def create_stew_game(self):
        """Игра тушения - нужно переворачивать ингредиенты"""
        tk.Label(self.container, text="🍲 ТУШИТЬ СОУС", 
                font=('Arial', 16, 'bold'), bg='#FFF8E7', fg='#FF6B6B').pack(pady=10)
        
        self.ingredients = ["🧅 Лук", "🥕 Морковь", "🍅 Томат", "🧄 Чеснок", "🌿 Травы"]
        self.stewed = []
        
        self.stew_frame = tk.Frame(self.container, bg='#FFF8E7')
        self.stew_frame.pack(pady=10)
        
        self.ingredient_buttons = []
        for ing in self.ingredients:
            btn = tk.Button(self.stew_frame, text=f"🔪 {ing}", command=lambda i=ing: self.stew_ingredient(i),
                           bg='#FFE5B4', font=('Arial', 11), width=15)
            btn.pack(pady=5)
            self.ingredient_buttons.append(btn)
        
        self.stew_label = tk.Label(self.container, text=f"Потушить: 0/{len(self.ingredients)}", 
                                   font=('Arial', 12), bg='#FFF8E7')
        self.stew_label.pack()
    
    def stew_ingredient(self, ingredient):
        if ingredient not in self.stewed:
            self.stewed.append(ingredient)
            self.stew_label.config(text=f"Потушить: {len(self.stewed)}/{len(self.ingredients)}")
            self.progress = int(len(self.stewed) / len(self.ingredients) * 100)
            
            # Обновляем кнопку
            for btn in self.ingredient_buttons:
                if ingredient in btn['text']:
                    btn.config(text=f"✅ {ingredient}", bg='#4CAF50', state='disabled')
            
            if len(self.stewed) >= len(self.ingredients):
                self.complete_game()
    
    def create_rice_game(self):
        """Игра приготовления риса - нужно промывать"""
        tk.Label(self.container, text="🍚 ПРИГОТОВИТЬ РИС", 
                font=('Arial', 16, 'bold'), bg='#FFF8E7', fg='#FF6B6B').pack(pady=10)
        
        self.water_count = 0
        self.rice_canvas = tk.Canvas(self.container, width=300, height=150, bg='#FFE5B4')
        self.rice_canvas.pack(pady=10)
        self.rice_canvas.create_oval(80, 50, 220, 130, fill='#F5DEB3')
        self.water_level = self.rice_canvas.create_rectangle(80, 130, 220, 130, fill='#87CEEB')
        
        self.water_btn = tk.Button(self.container, text="💧 ПРОМЫТЬ", command=self.wash_rice,
                                   bg='#4CAF50', fg='white', font=('Arial', 14), width=20, height=2)
        self.water_btn.pack(pady=10)
        
        self.water_label = tk.Label(self.container, text="Промывок: 0/5", 
                                    font=('Arial', 12), bg='#FFF8E7')
        self.water_label.pack()
    
    def wash_rice(self):
        self.water_count += 1
        self.water_label.config(text=f"Промывок: {self.water_count}/5")
        self.progress = self.water_count * 20
        
        # Анимация воды
        water_y = 130 - (self.water_count * 10)
        self.rice_canvas.coords(self.water_level, 80, water_y, 220, 130)
        
        if self.water_count >= 5:
            self.complete_game()
    
    def create_chopping_game(self):
        """Игра нарезки - нужно кликать по движущимся объектам"""
        tk.Label(self.container, text="🔪 НАРЕЗАТЬ ИНГРЕДИЕНТЫ", 
                font=('Arial', 16, 'bold'), bg='#FFF8E7', fg='#FF6B6B').pack(pady=10)
        
        self.chop_count = 0
        self.chop_target = 10
        
        self.chop_canvas = tk.Canvas(self.container, width=400, height=200, bg='#FFE5B4')
        self.chop_canvas.pack(pady=10)
        
        # Создаем движущиеся ингредиенты
        self.veggies = []
        for i in range(3):
            veg = self.chop_canvas.create_rectangle(
                random.randint(50, 350), random.randint(30, 170),
                random.randint(60, 380), random.randint(40, 180),
                fill='#F4A460', tags='veg'
            )
            self.veggies.append(veg)
        
        self.chop_canvas.bind('<Button-1>', self.on_chop)
        
        self.chop_label = tk.Label(self.container, text=f"Нарезано: 0/{self.chop_target}", 
                                   font=('Arial', 12), bg='#FFF8E7')
        self.chop_label.pack()
        
        self.move_veggies()
    
    def move_veggies(self):
        for veg in self.veggies:
            coords = self.chop_canvas.coords(veg)
            dx = random.randint(-10, 10)
            dy = random.randint(-10, 10)
            new_coords = [coords[0] + dx, coords[1] + dy, coords[2] + dx, coords[3] + dy]
            if 0 < new_coords[0] < 400 and 0 < new_coords[1] < 200:
                self.chop_canvas.coords(veg, new_coords)
        if self.chop_count < self.chop_target:
            self.parent.after(500, self.move_veggies)
    
    def on_chop(self, event):
        items = self.chop_canvas.find_withtag('veg')
        for veg in items:
            coords = self.chop_canvas.coords(veg)
            if coords[0] < event.x < coords[2] and coords[1] < event.y < coords[3]:
                self.chop_canvas.delete(veg)
                self.veggies.remove(veg)
                self.chop_count += 1
                self.chop_label.config(text=f"Нарезано: {self.chop_count}/{self.chop_target}")
                self.progress = int(self.chop_count / self.chop_target * 100)
                
                # Создаем новый ингредиент
                if self.chop_count < self.chop_target:
                    new_veg = self.chop_canvas.create_rectangle(
                        random.randint(50, 350), random.randint(30, 170),
                        random.randint(60, 380), random.randint(40, 180),
                        fill='#F4A460', tags='veg'
                    )
                    self.veggies.append(new_veg)
                
                if self.chop_count >= self.chop_target:
                    self.complete_game()
                break
    
    def create_click_game(self):
        """Обычная игра с кликами (как запасной вариант)"""
        tk.Label(self.container, text=f"🔥 {self.action.upper()} 🔥", 
                font=('Arial', 18, 'bold'), bg='#FFF8E7', fg='#FF6B6B').pack(pady=30)
        
        self.click_count = 0
        self.click_target = 15
        
        self.click_btn = tk.Button(self.container, text="🌀 НАЖМИ ДЛЯ ГОТОВКИ", command=self.click_action,
                                   bg='#FF6B6B', fg='white', font=('Arial', 14), width=25, height=3)
        self.click_btn.pack(pady=20)
        
        self.click_label = tk.Label(self.container, text=f"Нажатий: 0/{self.click_target}", 
                                    font=('Arial', 12), bg='#FFF8E7')
        self.click_label.pack()
    
    def click_action(self):
        self.click_count += 1
        self.click_label.config(text=f"Нажатий: {self.click_count}/{self.click_target}")
        self.progress = int(self.click_count / self.click_target * 100)
        
        if self.click_count >= self.click_target:
            self.complete_game()
    
    def complete_game(self):
        """Завершение игры"""
        self.timer_active = False
        if hasattr(self, 'timer'):
            self.parent.after_cancel(self.timer)
        self.on_complete()

class CulinaryAdventuresApp:
    def __init__(self, root):
        self.root = root
        self.root.title("🍳 Кулинарные приключения")
        self.root.geometry("900x750")
        self.root.configure(bg='#FFF8E7')
        self.root.minsize(700, 600)
        self.root.resizable(True, True)
        
        self.sound_manager = SoundManager()
        self.save_file = "culinary_save.json"
        self.load_game()
        
        self.current_location = None
        self.current_recipe = None
        self.current_step = 0
        self.found_items = []
        self.cook_progress = 0
        
        self.check_daily_bonus()
        self.setup_main_menu()
    
    def load_game(self):
        default_data = {
            "player_name": "Шеф-стажер",
            "player_level": 1,
            "player_exp": 0,
            "player_coins": 100,
            "player_stars": 0,
            "unlocked_locations": ["Италия"],
            "unlocked_recipes": {"Италия": []},
            "completed_recipes": [],
            "achievements": {},
            "last_daily": None
        }
        
        if os.path.exists(self.save_file):
            try:
                with open(self.save_file, 'r', encoding='utf-8') as f:
                    saved = json.load(f)
                    default_data.update(saved)
            except:
                pass
        
        self.player_name = default_data["player_name"]
        self.player_level = default_data["player_level"]
        self.player_exp = default_data["player_exp"]
        self.player_coins = default_data["player_coins"]
        self.player_stars = default_data["player_stars"]
        self.unlocked_locations = default_data["unlocked_locations"]
        self.unlocked_recipes = default_data["unlocked_recipes"]
        self.completed_recipes = default_data["completed_recipes"]
        self.achievements = default_data["achievements"]
        self.last_daily_bonus = default_data["last_daily"]
        
        all_countries = ["Италия", "Япония", "Мексика", "Франция", "Таиланд", "Индия", "Корея", "Греция", "Марокко"]
        for loc in all_countries:
            if loc not in self.unlocked_recipes:
                self.unlocked_recipes[loc] = []
    
    def save_game(self):
        save_data = {
            "player_name": self.player_name,
            "player_level": self.player_level,
            "player_exp": self.player_exp,
            "player_coins": self.player_coins,
            "player_stars": self.player_stars,
            "unlocked_locations": self.unlocked_locations,
            "unlocked_recipes": self.unlocked_recipes,
            "completed_recipes": self.completed_recipes,
            "achievements": self.achievements,
            "last_daily": self.last_daily_bonus
        }
        with open(self.save_file, 'w', encoding='utf-8') as f:
            json.dump(save_data, f, ensure_ascii=False, indent=2)
    
    def check_daily_bonus(self):
        today = datetime.now().strftime("%Y-%m-%d")
        if self.last_daily_bonus != today:
            self.last_daily_bonus = today
            self.player_coins += 50
            self.save_game()
    
    def add_exp(self, amount):
        self.player_exp += amount
        while self.player_exp >= 100:
            self.player_level += 1
            self.player_exp -= 100
            self.show_level_up()
        self.save_game()
    
    def show_level_up(self):
        level_up = tk.Toplevel(self.root)
        level_up.title("Уровень повышен!")
        level_up.geometry("300x200")
        level_up.configure(bg='#FFF8E7')
        level_up.transient(self.root)
        level_up.grab_set()
        
        tk.Label(level_up, text="🎉 УРОВЕНЬ ПОВЫШЕН! 🎉", 
                font=('Arial', 14, 'bold'), bg='#FFF8E7', fg='#FF6B6B').pack(pady=20)
        tk.Label(level_up, text=f"Теперь вы {self.player_level} уровень!", 
                font=('Arial', 12), bg='#FFF8E7').pack(pady=10)
        tk.Button(level_up, text="Отлично!", command=level_up.destroy,
                 bg='#FF6B6B', fg='white', font=('Arial', 12)).pack(pady=20)
        self.root.after(3000, level_up.destroy)
    
    def check_achievements(self):
        achievements_data = {
            "first_recipe": {"name": "👨‍🍳 Первый шаг", "desc": "Приготовьте первое блюдо", "condition": len(self.completed_recipes) >= 1, "reward": 50},
            "traveler": {"name": "🌍 Путешественник", "desc": "Откройте 5 локаций", "condition": len(self.unlocked_locations) >= 5, "reward": 100},
            "star_chef": {"name": "⭐ Звездный повар", "desc": "Соберите 30 звезд", "condition": self.player_stars >= 30, "reward": 150},
            "collector": {"name": "📚 Коллекционер", "desc": "Откройте 15 рецептов", "condition": len(self.completed_recipes) >= 15, "reward": 200},
            "master": {"name": "👑 Мастер-шеф", "desc": "Достигните 10 уровня", "condition": self.player_level >= 10, "reward": 500},
            "millionaire": {"name": "💰 Миллионер", "desc": "Соберите 1000 монет", "condition": self.player_coins >= 1000, "reward": 300}
        }
        
        new_achievements = []
        for key, data in achievements_data.items():
            if data["condition"] and key not in self.achievements:
                self.achievements[key] = True
                self.player_coins += data["reward"]
                new_achievements.append((data["name"], data["reward"]))
                self.save_game()
        
        if new_achievements:
            self.show_achievement_notification(new_achievements)
    
    def show_achievement_notification(self, achievements):
        notif = tk.Toplevel(self.root)
