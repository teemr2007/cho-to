            btn.grid(row=row, column=col, padx=15, pady=8)
    
    def find_item(self, item, progress_bar, items):
        if item not in self.found_items:
            self.found_items.append(item)
            self.progress_label.config(text=f"Найдено: {len(self.found_items)}/{len(items)}")
            progress_bar['value'] = len(self.found_items)
            messagebox.showinfo("Успех!", f"Вы нашли {item}! 🎉")
            if len(self.found_items) == len(items):
                messagebox.showinfo("Отлично!", "Все ингредиенты найдены!")
                self.current_step += 1
                self.next_step()
    
