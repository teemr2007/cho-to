                        font=('Arial', 20, 'bold'), bg='#FFF8E7', fg='#FF6B6B')
        title.pack(pady=10)
        
        # Анимированная подсказка
        self.tip_label = tk.Label(parent, text="✨ Водите мышью по тесту! ✨", 
                                  font=('Arial', 11), bg='#FFF8E7', fg='#FF9800')
        self.tip_label.pack()
        self.animate_tip()
        
        self.dough_canvas = tk.Canvas(parent, width=350, height=250, bg='#FFE5B4', 
                                      relief='ridge', highlightthickness=2)
        self.dough_canvas.pack(pady=15)
        
        # Рисуем красивую миску
        self.dough_canvas.create_oval(60, 100, 290, 210, fill='#F5DEB3', outline='#8B4513', width=3)
        self.dough_canvas.create_arc(60, 100, 290, 210, start=0, extent=180, 
                                      fill='#FFE4B5', outline='')
        self.dough_text = self.dough_canvas.create_text(175, 155, text="🥄", font=('Arial', 45))
        
        # Параметры игры
        self.time_remaining = 12
        self.last_x, self.last_y = 0, 0
        self.total_movement = 0
        self.max_movement = 600
        
        # Прогресс-бары
        time_frame = tk.Frame(parent, bg='#FFF8E7')
        time_frame.pack(pady=5)
        tk.Label(time_frame, text="⏱️ Время:", font=('Arial', 10), bg='#FFF8E7').pack(side='left')
        self.time_progress = ttk.Progressbar(time_frame, length=250, mode='determinate', maximum=12)
        self.time_progress.pack(side='left', padx=10)
        self.time_label = tk.Label(time_frame, text=f"{self.time_remaining} сек", 
                                   font=('Arial', 10), bg='#FFF8E7')
        self.time_label.pack(side='left')
        
        move_frame = tk.Frame(parent, bg='#FFF8E7')
        move_frame.pack(pady=5)
        tk.Label(move_frame, text="🥄 Прогресс:", font=('Arial', 10), bg='#FFF8E7').pack(side='left')
        self.move_progress = ttk.Progressbar(move_frame, length=250, mode='determinate', maximum=100)
        self.move_progress.pack(side='left', padx=10)
        self.move_label = tk.Label(move_frame, text="0%", font=('Arial', 10), bg='#FFF8E7', fg='#4CAF50')
        self.move_label.pack(side='left')
        
        self.dough_canvas.bind('<Motion>', self.on_dough_move)
        self.start_dough_timer()
        
        instruction = tk.Label(parent, text="💡 Совет: быстро водите мышью по миске для ускорения!", 
                              font=('Arial', 9), bg='#FFF8E7', fg='gray')
        instruction.pack(pady=10)
    
    def animate_tip(self):
        """Анимация подсказки"""
        colors = ['#FF9800', '#FF6B6B', '#4CAF50', '#2196F3']
        for i, color in enumerate(colors):
            self.parent.after(i * 500, lambda c=color: self.tip_label.config(fg=c))
        self.parent.after(2000, self.animate_tip)
    
    def start_dough_timer(self):
        if self.timer:
            try:
                self.parent.after_cancel(self.timer)
            except:
                pass
        self.timer = self.parent.after(1000, self.update_dough_timer)
    
    def update_dough_timer(self):
        self.time_remaining -= 1
        self.time_progress['value'] = self.time_remaining
        self.time_label.config(text=f"{self.time_remaining} сек")
        
        if self.total_movement < self.max_movement:
            self.total_movement = min(self.max_movement, self.total_movement + 8)
            percent = int(self.total_movement / self.max_movement * 100)
            self.move_progress['value'] = percent
            self.move_label.config(text=f"{percent}%")
        
        if self.time_remaining > 0:
            self.timer = self.parent.after(1000, self.update_dough_timer)
        else:
            if self.total_movement >= self.max_movement:
                self.dough_canvas.unbind('<Motion>')
                self.complete_game()
            else:
                if messagebox.askyesno("Время вышло!", "Нужно активнее мешать тесто! Попробовать ещё раз?"):
                    self.reset_dough_game()
                else:
                    self.dough_canvas.unbind('<Motion>')
    
    def reset_dough_game(self):
        self.time_remaining = 12
        self.total_movement = 0
        self.last_x, self.last_y = 0, 0
        self.time_progress['value'] = 12
        self.time_label.config(text="12 сек")
        self.move_progress['value'] = 0
        self.move_label.config(text="0%")
        self.dough_canvas.bind('<Motion>', self.on_dough_move)
        self.start_dough_timer()
    
    def on_dough_move(self, event):
        if self.time_remaining <= 0:
            return
        
        x, y = event.x, event.y
        if 60 < x < 290 and 100 < y < 210:
            if self.last_x != 0 and self.last_y != 0:
                dist = ((x - self.last_x) ** 2 + (y - self.last_y) ** 2) ** 0.5
                gain = min(20, int(dist * 2))
                if self.total_movement < self.max_movement:
                    self.total_movement = min(self.max_movement, self.total_movement + gain)
                    percent = int(self.total_movement / self.max_movement * 100)
                    self.move_progress['value'] = percent
                    self.move_label.config(text=f"{percent}%")
                    
                    # Анимация
                    self.dough_canvas.delete('spoon')
                    spoon = self.dough_canvas.create_text(x, y, text="🥄", font=('Arial', 35), tags='spoon')
                    ParticleEffect(self.dough_canvas, x, y, '#FFD700', 3)
                    self.parent.after(200, lambda: self.dough_canvas.delete(spoon))
            
            self.last_x, self.last_y = x, y
            
            if self.total_movement >= self.max_movement:
                self.dough_canvas.unbind('<Motion>')
                if self.timer:
                    try:
                        self.parent.after_cancel(self.timer)
                    except:
                        pass
                self.complete_game()
    
    def create_pasta_game(self, parent):
        """Улучшенная игра варки пасты"""
        tk.Label(parent, text="🍝 СВАРИТЬ ПАСТУ", 
                font=('Arial', 20, 'bold'), bg='#FFF8E7', fg='#FF6B6B').pack(pady=10)
        
        self.temp = 0
        self.target_temp = 100
        self.time_left = 50
        self.pasta_progress = 0
        
        # Термометр с анимацией
        self.temp_canvas = tk.Canvas(parent, width=250, height=250, bg='white', relief='ridge')
        self.temp_canvas.pack(pady=10)
        self.update_thermometer()
        
        # Кнопки управления
        btn_frame = tk.Frame(parent, bg='#FFF8E7')
        btn_frame.pack(pady=10)
        
        self.heat_btn = tk.Button(btn_frame, text="🔥 🔥 🔥", command=lambda: self.change_temp(8),
                                 bg='#F44336', fg='white', font=('Arial', 14), width=8, height=2)
        self.heat_btn.pack(side='left', padx=15)
        self.cool_btn = tk.Button(btn_frame, text="❄️ ❄️ ❄️", command=lambda: self.change_temp(-8),
                                 bg='#2196F3', fg='white', font=('Arial', 14), width=8, height=2)
        self.cool_btn.pack(side='left', padx=15)
        
        self.temp_label = tk.Label(parent, text=f"🌡️ Температура: {self.temp}°C / {self.target_temp}°C", 
                                   font=('Arial', 12), bg='#FFF8E7')
        self.temp_label.pack()
        
        self.time_label = tk.Label(parent, text=f"⏱️ Осталось: {self.time_left} сек", 
                                   font=('Arial', 12), bg='#FFF8E7')
        self.time_label.pack()
        
        self.progress_bar = ttk.Progressbar(parent, length=350, mode='determinate', maximum=100)
        self.progress_bar.pack(pady=10)
        
        self.timer = self.parent.after(1000, self.update_pasta_timer)
    
    def update_thermometer(self):
        self.temp_canvas.delete('all')
        # Красивый термометр
        self.temp_canvas.create_rectangle(100, 200, 150, 30, fill='#E0E0E0', outline='#333', width=2)
        height = 170 * (self.temp / 100)
        self.temp_canvas.create_rectangle(100, 200 - height, 150, 200, fill='#F44336', outline='')
        self.temp_canvas.create_oval(90, 200, 160, 240, fill='#F44336', outline='#333', width=2)
        
        # Градусник
        for i in range(0, 101, 20):
            y = 200 - 170 * (i / 100)
            self.temp_canvas.create_line(150, y, 160, y, fill='#333')
            self.temp_canvas.create_text(165, y, text=f"{i}°", font=('Arial', 8))
        
        self.temp_canvas.create_text(125, 15, text=f"{self.temp}°C", font=('Arial', 12, 'bold'), fill='#F44336')
    
    def change_temp(self, delta):
        self.temp = max(0, min(100, self.temp + delta))
        self.update_thermometer()
        self.temp_label.config(text=f"🌡️ Температура: {self.temp}°C / {self.target_temp}°C")
        
        # Эффект при достижении цели
        if 85 <= self.temp <= 100:
            gain = 4 if 90 <= self.temp <= 100 else 2
            self.pasta_progress = min(100, self.pasta_progress + gain)
            self.progress_bar['value'] = self.pasta_progress
            if self.pasta_progress >= 100:
                self.complete_game()
    
    def update_pasta_timer(self):
        if not self.timer_active:
            return
        self.time_left -= 1
        self.time_label.config(text=f"⏱️ Осталось: {self.time_left} сек")
        if self.time_left > 0:
            self.timer = self.parent.after(1000, self.update_pasta_timer)
        else:
            if self.pasta_progress >= 100:
                self.complete_game()
            else:
                if messagebox.askyesno("Время вышло!", "Паста не готова! Попробовать ещё раз?"):
                    self.reset_pasta_game()
    
    def reset_pasta_game(self):
        self.temp = 0
        self.pasta_progress = 0
        self.time_left = 50
        self.progress_bar['value'] = 0
        self.update_thermometer()
        self.temp_label.config(text=f"🌡️ Температура: {self.temp}°C / {self.target_temp}°C")
        self.time_label.config(text=f"⏱️ Осталось: {self.time_left} сек")
        if self.timer:
            try:
                self.parent.after_cancel(self.timer)
            except:
                pass
        self.timer = self.parent.after(1000, self.update_pasta_timer)
    
    def create_whip_game(self, parent):
        """Улучшенная игра взбивания"""
        tk.Label(parent, text="🥣 ВЗБИТЬ КРЕМ", 
                font=('Arial', 20, 'bold'), bg='#FFF8E7', fg='#FF6B6B').pack(pady=10)
        
        self.whip_count = 0
        self.whip_target = 30
        
        # Анимированная миска
        self.whip_canvas = tk.Canvas(parent, width=300, height=220, bg='#FFE5B4', relief='ridge')
        self.whip_canvas.pack(pady=10)
        self.whip_canvas.create_oval(60, 70, 240, 180, fill='#F5DEB3', outline='#8B4513', width=2)
        self.whip_text = self.whip_canvas.create_text(150, 125, text="🥄", font=('Arial', 50))
        
        # Анимированная кнопка
        self.whip_btn = tk.Button(parent, text="👋 ВЗБИВАЙ! 👋", command=self.whip_action,
                                  bg='#FF6B6B', fg='white', font=('Arial', 16, 'bold'), 
                                  width=20, height=2, relief='raised')
        self.whip_btn.pack(pady=10)
        
        self.whip_label = tk.Label(parent, text=f"📊 Взбиваний: 0/{self.whip_target}", 
                                   font=('Arial', 12), bg='#FFF8E7')
        self.whip_label.pack()
        
        self.combo_label = tk.Label(parent, text="", font=('Arial', 12, 'bold'), bg='#FFF8E7', fg='#FFD700')
        self.combo_label.pack()
        
        self.whip_progress = ttk.Progressbar(parent, length=350, mode='determinate', maximum=100)
        self.whip_progress.pack(pady=10)
        
        self.combo_timer = None
    
    def whip_action(self):
        self.whip_count += 1
        self.combo += 1
        
        # Анимация взбивания
        for _ in range(3):
            self.whip_canvas.coords(self.whip_text, 150 + random.randint(-15, 15), 
                                    125 + random.randint(-15, 15))
        self.whip_canvas.after(100, lambda: self.whip_canvas.coords(self.whip_text, 150, 125))
        
        percent = int(self.whip_count / self.whip_target * 100)
        self.whip_label.config(text=f"📊 Взбиваний: {self.whip_count}/{self.whip_target}")
        self.whip_progress['value'] = percent
        
        # Эффект частиц
        ParticleEffect(self.whip_canvas, 150, 125, '#FFD700', 5)
        
        if self.combo >= 3:
            self.combo_label.config(text=f"🔥 КОМБО x{self.combo}! +1 🔥")
            if self.combo % 3 == 0 and self.whip_count < self.whip_target:
                self.whip_count = min(self.whip_target, self.whip_count + 1)
                self.whip_label.config(text=f"📊 Взбиваний: {self.whip_count}/{self.whip_target}")
                self.whip_progress['value'] = int(self.whip_count / self.whip_target * 100)
        
        if self.combo_timer:
            self.parent.after_cancel(self.combo_timer)
        self.combo_timer = self.parent.after(2000, self.reset_combo)
        
        if self.whip_count >= self.whip_target:
            self.complete_game()
    
    def reset_combo(self):
        self.combo = 0
        self.combo_label.config(text="")
    
    def create_stew_game(self, parent):
        """Улучшенная игра тушения"""
        tk.Label(parent, text="🍲 ТУШИТЬ СОУС", 
                font=('Arial', 20, 'bold'), bg='#FFF8E7', fg='#FF6B6B').pack(pady=10)
        
        self.ingredients = ["🧅 Лук", "🥕 Морковь", "🍅 Томат", "🧄 Чеснок", "🌿 Травы", "🧂 Специи", "🍄 Грибы"]
        self.stewed = []
        
        self.stew_frame = tk.Frame(parent, bg='#FFF8E7')
        self.stew_frame.pack(pady=10)
        
        self.stew_progress = ttk.Progressbar(parent, length=350, mode='determinate', 
                                            maximum=len(self.ingredients))
        self.stew_progress.pack(pady=10)
        
        self.ingredient_buttons = []
        for i, ing in enumerate(self.ingredients):
            btn = tk.Button(self.stew_frame, text=f"🔪 {ing}", command=lambda i=ing: self.stew_ingredient(i),
                           bg='#FFE5B4', font=('Arial', 11), width=18, height=2)
            btn.grid(row=i//3, column=i%3, padx=10, pady=5)
            self.ingredient_buttons.append(btn)
        
        self.stew_label = tk.Label(parent, text=f"📊 Потушить: 0/{len(self.ingredients)}", 
