    def answer_quiz(self, selected, correct):
        if selected == correct:
            messagebox.showinfo("✅ Правильно! 🎉", "Отличные кулинарные знания! Продолжаем! ✅")
            self.current_step += 1
            self.next_step()
        else:
            messagebox.showerror("❌ Ошибка! ❌", "Попробуйте еще раз! Внимательно прочитайте вопрос.")
    
    def complete_quest(self):
        location = None
        for loc in self.unlocked_recipes.keys():
            if self.current_recipe in self.get_recipes_for_location(loc):
                location = loc
                break
        
        if location and self.current_recipe not in self.completed_recipes:
            self.completed_recipes.append(self.current_recipe)
            self.games_played += 1
            
            reward_exp = 60
            reward_stars = 4
            reward_coins = random.randint(40, 90)
            
            self.add_exp(reward_exp)
            self.player_stars += reward_stars
            self.player_coins += reward_coins
            
            recipes = self.get_recipes_for_location(location)
            if self.current_recipe in recipes:
                current_index = recipes.index(self.current_recipe)
                if current_index + 1 < len(recipes):
                    next_recipe = recipes[current_index + 1]
                    if next_recipe not in self.unlocked_recipes.get(location, []):
                        self.unlocked_recipes[location].append(next_recipe)
            
            total_completed = len(self.completed_recipes)
            all_locations = ["Италия", "Япония", "Мексика", "Франция", "Таиланд", "Индия", "Корея", "Греция", "Марокко", "Турция", "Испания"]
            expected_unlocked = 1 + (total_completed // 3)
            if expected_unlocked > len(all_locations):
                expected_unlocked = len(all_locations)
            
            for i in range(len(self.unlocked_locations), expected_unlocked):
                if i < len(all_locations):
                    new_loc = all_locations[i]
                    if new_loc not in self.unlocked_locations:
                        self.unlocked_locations.append(new_loc)
                        messagebox.showinfo("🌍 НОВАЯ ЛОКАЦИЯ ОТКРЫТА! 🌍", 
                                          f"Поздравляем! Вы открыли {new_loc}!\nПродолжайте кулинарное путешествие!")
            
            self.save_game()
            self.check_achievements()
            self.show_result_screen(reward_exp, reward_stars, reward_coins)
    
