        """Улучшенная игра приготовления риса"""
        tk.Label(parent, text="🍚 ПРИГОТОВИТЬ РИС", 
                font=('Arial', 20, 'bold'), bg='#FFF8E7', fg='#FF6B6B').pack(pady=10)
        
        self.water_count = 0
        self.water_target = 8
        
        self.rice_canvas = tk.Canvas(parent, width=350, height=200, bg='#FFE5B4', relief='ridge')
        self.rice_canvas.pack(pady=10)
        
        # Красивая кастрюля
        self.rice_canvas.create_rectangle(90, 40, 260, 160, fill='#C0C0C0', outline='#808080', width=3)
        self.rice_canvas.create_oval(90, 40, 260, 70, fill='#A0A0A0', outline='#808080', width=2)
        self.rice_canvas.create_text(175, 100, text="🍚", font=('Arial', 45))
        self.water_level = self.rice_canvas.create_rectangle(92, 160, 258, 160, fill='#87CEEB', tags='water')
        
        self.water_btn = tk.Button(parent, text="💧 ПРОМЫТЬ РИС 💧", command=self.wash_rice,
