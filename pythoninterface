        self.stew_label.pack()
        
        self.cauldron = tk.Canvas(parent, width=200, height=100, bg='#FFF8E7', highlightthickness=0)
        self.cauldron.pack(pady=10)
        self.cauldron.create_oval(50, 40, 150, 80, fill='#8B4513')
        self.cauldron.create_text(100, 60, text="🍲", font=('Arial', 30))
    
    def stew_ingredient(self, ingredient):
        if ingredient not in self.stewed:
            self.stewed.append(ingredient)
            self.stew_label.config(text=f"📊 Потушить: {len(self.stewed)}/{len(self.ingredients)}")
            self.stew_progress['value'] = len(self.stewed)
            
            for btn in self.ingredient_buttons:
                if ingredient in btn['text']:
                    btn.config(text=f"✅ {ingredient}", bg='#4CAF50', state='disabled')
                    ParticleEffect(self.cauldron, 100, 60, '#FF9800', 5)
            
            if len(self.stewed) >= len(self.ingredients):
                self.complete_game()
    
