            if item in self.found_items:
                btn = tk.Button(items_frame, text=f"✅ {item}", bg='#4CAF50', fg='white',
                              font=('Arial', 12), width=20, height=2, state='disabled')
            else:
                btn = tk.Button(items_frame, text=f"🔍 {item}", 
                               command=lambda i=item, pb=progress_bar, its=items: self.find_item(i, pb, its),
