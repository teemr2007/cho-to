    def create_chopping_game(self, parent):
        """Улучшенная игра нарезки"""
        tk.Label(parent, text="🔪 НАРЕЗАТЬ ИНГРЕДИЕНТЫ", 
                font=('Arial', 20, 'bold'), bg='#FFF8E7', fg='#FF6B6B').pack(pady=10)
        
        self.chop_count = 0
        self.chop_target = 15
        
        self.chop_canvas = tk.Canvas(parent, width=500, height=280, bg='#FFE5B4', relief='ridge')
        self.chop_canvas.pack(pady=10)
        
        # Разделочная доска
        self.chop_canvas.create_rectangle(20, 20, 480, 260, fill='#DEB887', outline='#8B4513', width=3)
        
        self.veggies = []
        veg_names = ["🥕 Морковь", "🍅 Помидор", "🧅 Лук", "🥒 Огурец", "🌶️ Перец", "🧄 Чеснок"]
        for i in range(5):
            veg = {
                'id': self.chop_canvas.create_text(
                    random.randint(60, 440), random.randint(50, 230),
                    text=random.choice(veg_names), font=('Arial', 28), tags='veg'
                ),
                'x': random.randint(60, 440),
                'y': random.randint(50, 230),
                'dx': random.choice([-1, 1]) * random.randint(2, 5),
                'dy': random.choice([-1, 1]) * random.randint(2, 5)
            }
            self.veggies.append(veg)
        
        self.chop_canvas.bind('<Button-1>', self.on_chop)
        
        self.chop_label = tk.Label(parent, text=f"🔪 Нарезано: 0/{self.chop_target}", 
                                   font=('Arial', 12), bg='#FFF8E7')
        self.chop_label.pack()
        
        self.chop_progress = ttk.Progressbar(parent, length=350, mode='determinate', 
                                            maximum=self.chop_target)
        self.chop_progress.pack(pady=10)
        
        self.move_veggies()
    
    def move_veggies(self):
        if self.chop_count >= self.chop_target:
            return
        for veg in self.veggies:
            veg['x'] += veg['dx']
            veg['y'] += veg['dy']
            
            if veg['x'] < 50 or veg['x'] > 450:
                veg['dx'] = -veg['dx']
                veg['x'] = max(50, min(450, veg['x']))
            if veg['y'] < 40 or veg['y'] > 240:
                veg['dy'] = -veg['dy']
                veg['y'] = max(40, min(240, veg['y']))
            
            self.chop_canvas.coords(veg['id'], veg['x'], veg['y'])
        
        if self.chop_count < self.chop_target:
            self.parent.after(50, self.move_veggies)
    
    def on_chop(self, event):
        for veg in self.veggies[:]:
            coords = self.chop_canvas.coords(veg['id'])
            if (coords[0] - 35 < event.x < coords[0] + 35 and 
                coords[1] - 35 < event.y < coords[1] + 35):
                self.chop_canvas.delete(veg['id'])
                self.veggies.remove(veg)
                self.chop_count += 1
                self.chop_label.config(text=f"🔪 Нарезано: {self.chop_count}/{self.chop_target}")
                self.chop_progress['value'] = self.chop_count
                
                # Эффект нарезки
                ParticleEffect(self.chop_canvas, event.x, event.y, '#FFD700', 8)
                
                if self.chop_count < self.chop_target:
                    veg_names = ["🥕 Морковь", "🍅 Помидор", "🧅 Лук", "🥒 Огурец", "🌶️ Перец", "🧄 Чеснок"]
                    new_veg = {
                        'id': self.chop_canvas.create_text(
                            random.randint(60, 440), random.randint(50, 230),
                            text=random.choice(veg_names), font=('Arial', 28), tags='veg'
                        ),
                        'x': random.randint(60, 440),
                        'y': random.randint(50, 230),
                        'dx': random.choice([-1, 1]) * random.randint(2, 5),
                        'dy': random.choice([-1, 1]) * random.randint(2, 5)
                    }
                    self.veggies.append(new_veg)
                
                if self.chop_count >= self.chop_target:
                    self.complete_game()
                break
    
    def create_click_game(self, parent):
        """Обычная игра с кликами"""
        tk.Label(parent, text=f"🔥 {self.action.upper()} 🔥", 
                font=('Arial', 20, 'bold'), bg='#FFF8E7', fg='#FF6B6B').pack(pady=30)
        
        self.click_count = 0
        self.click_target = 25
        
        self.click_btn = tk.Button(parent, text="🌀 НАЖМИ ДЛЯ ГОТОВКИ 🌀", command=self.click_action,
                                   bg='#FF6B6B', fg='white', font=('Arial', 16, 'bold'), 
                                   width=25, height=3, relief='raised')
        self.click_btn.pack(pady=20)
        
        self.click_label = tk.Label(parent, text=f"📊 Нажатий: 0/{self.click_target}", 
                                    font=('Arial', 12), bg='#FFF8E7')
        self.click_label.pack()
        
        self.click_progress = ttk.Progressbar(parent, length=350, mode='determinate', 
                                             maximum=self.click_target)
        self.click_progress.pack(pady=10)
    
    def click_action(self):
        self.click_count += 1
        self.click_label.config(text=f"📊 Нажатий: {self.click_count}/{self.click_target}")
        self.click_progress['value'] = self.click_count
        
        self.click_btn.config(relief='sunken')
        self.parent.after(100, lambda: self.click_btn.config(relief='raised'))
        
        if self.click_count >= self.click_target:
            self.complete_game()
    
    def complete_game(self):
        self.timer_active = False
        if hasattr(self, 'timer') and self.timer:
            try:
                self.parent.after_cancel(self.timer)
            except:
                pass
        if hasattr(self, 'combo_timer') and self.combo_timer:
            try:
                self.parent.after_cancel(self.combo_timer)
            except:
                pass
        
        # Показываем красивую анимацию завершения
        success_frame = tk.Toplevel(self.parent)
        success_frame.title("Готово!")
        success_frame.geometry("300x200")
        success_frame.configure(bg='#FFF8E7')
        success_frame.transient(self.parent)
        
        tk.Label(success_frame, text="✨ ИДЕАЛЬНО! ✨", 
                font=('Arial', 18, 'bold'), bg='#FFF8E7', fg='#FF6B6B').pack(pady=30)
        tk.Label(success_frame, text="Блюдо приготовлено идеально!", 
                font=('Arial', 12), bg='#FFF8E7').pack()
        tk.Button(success_frame, text="Отлично!", command=success_frame.destroy,
                 bg='#4CAF50', fg='white', font=('Arial', 12)).pack(pady=20)
        self.parent.after(2000, success_frame.destroy)
        
        self.on_complete()

