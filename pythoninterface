    def load_game(self):
        default_data = {
            "player_name": "Шеф-стажер",
            "player_level": 1,
            "player_exp": 0,
            "player_coins": 200,
            "player_stars": 0,
            "unlocked_locations": ["Италия"],
            "unlocked_recipes": {"Италия": []},
            "completed_recipes": [],
            "achievements": {},
            "last_daily": None,
            "total_score": 0,
            "games_played": 0
        }
        
        if os.path.exists(self.save_file):
            try:
                with open(self.save_file, 'r', encoding='utf-8') as f:
                    saved = json.load(f)
                    default_data.update(saved)
            except:
                pass
        
        self.player_name = default_data["player_name"]
        self.player_level = default_data["player_level"]
        self.player_exp = default_data["player_exp"]
        self.player_coins = default_data["player_coins"]
        self.player_stars = default_data["player_stars"]
        self.unlocked_locations = default_data["unlocked_locations"]
        self.unlocked_recipes = default_data["unlocked_recipes"]
        self.completed_recipes = default_data["completed_recipes"]
        self.achievements = default_data["achievements"]
        self.last_daily_bonus = default_data["last_daily"]
        self.total_score = default_data.get("total_score", 0)
        self.games_played = default_data.get("games_played", 0)
        
        all_countries = ["Италия", "Япония", "Мексика", "Франция", "Таиланд", "Индия", "Корея", "Греция", "Марокко", "Турция", "Испания"]
        for loc in all_countries:
            if loc not in self.unlocked_recipes:
                self.unlocked_recipes[loc] = []
    
    def save_game(self):
        save_data = {
            "player_name": self.player_name,
            "player_level": self.player_level,
            "player_exp": self.player_exp,
            "player_coins": self.player_coins,
            "player_stars": self.player_stars,
            "unlocked_locations": self.unlocked_locations,
            "unlocked_recipes": self.unlocked_recipes,
            "completed_recipes": self.completed_recipes,
            "achievements": self.achievements,
            "last_daily": self.last_daily_bonus,
            "total_score": self.total_score,
            "games_played": self.games_played
        }
        with open(self.save_file, 'w', encoding='utf-8') as f:
            json.dump(save_data, f, ensure_ascii=False, indent=2)
    
    def check_daily_bonus(self):
        today = datetime.now().strftime("%Y-%m-%d")
        if self.last_daily_bonus != today:
            self.last_daily_bonus = today
            bonus = random.randint(50, 150)
            self.player_coins += bonus
            self.save_game()
            self.show_flying_coins_animation(bonus)
    
