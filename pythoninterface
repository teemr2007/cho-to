        self.whip_canvas.create_oval(50, 80, 200, 160, fill='#F5DEB3')
        self.whip_text = self.whip_canvas.create_text(125, 120, text="🥄", font=('Arial', 50))
        
        self.whip_btn = tk.Button(self.container, text="👋 ВЗБИВАЙ!", command=self.whip_action,
                                  bg='#FF6B6B', fg='white', font=('Arial', 14), width=20, height=2)
        self.whip_btn.pack(pady=10)
        
        self.whip_label = tk.Label(self.container, text=f"Взбиваний: 0/{self.whip_target}", 
