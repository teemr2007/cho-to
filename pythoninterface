        tk.Label(header, text="📚 МОЯ КОЛЛЕКЦИЯ", font=('Arial', 18, 'bold'),
                bg='#FF6B6B', fg='white').pack(side='left', padx=20)
        
        canvas = tk.Canvas(self.root, bg='#FFF8E7', highlightthickness=0)
        scrollbar = ttk.Scrollbar(self.root, orient='vertical', command=canvas.yview)
        scrollable = tk.Frame(canvas, bg='#FFF8E7')
        
        scrollable.bind('<Configure>', lambda e: canvas.configure(scrollregion=canvas.bbox('all')))
        canvas.create_window((0, 0), window=scrollable, anchor='nw')
        canvas.configure(yscrollcommand=scrollbar.set)
        canvas.pack(side='left', fill='both', expand=True)
        scrollbar.pack(side='right', fill='y')
        
        recipes_shown = False
        all_locations = ["Италия", "Япония", "Мексика", "Франция", "Таиланд", "Индия", "Корея", "Греция", "Марокко"]
        for location in all_locations:
            recipes_in_loc = [r for r in self.completed_recipes 
                            if r in self.get_recipes_for_location(location)]
            if recipes_in_loc:
                recipes_shown = True
                location_frame = tk.LabelFrame(scrollable, text=f"📍 {location}", 
                                              bg='#FFF8E7', font=('Arial', 12, 'bold'))
                location_frame.pack(fill='x', padx=10, pady=5)
                for recipe in recipes_in_loc:
                    recipe_frame = tk.Frame(location_frame, bg='#FFE5B4')
                    recipe_frame.pack(fill='x', padx=5, pady=3)
                    tk.Label(recipe_frame, text=f"🍽️ {recipe}", 
                            font=('Arial', 10), bg='#FFE5B4').pack(side='left', padx=10, pady=5)
                    tk.Button(recipe_frame, text="📖 Рецепт", 
                             command=lambda r=recipe: self.show_recipe_detail(r),
                             bg='#FF6B6B', fg='white', font=('Arial', 9)).pack(side='right', padx=10)
        
        if not recipes_shown:
            tk.Label(scrollable, text="Пока нет открытых рецептов.\nПройдите квесты!", 
                    font=('Arial', 12), bg='#FFF8E7', justify='center').pack(pady=50)
    
