    def open_location(self, location):
        self.current_location = location
        self.clear_window()
        
        header = tk.Frame(self.root, bg='#FF6B6B', height=80)
        header.pack(fill='x')
        header.pack_propagate(False)
        tk.Button(header, text="← Назад", command=self.setup_main_menu,
                 bg='#FF6B6B', fg='white', font=('Arial', 12), relief='flat').pack(side='left', padx=10)
        tk.Label(header, text=f"📍 {location}", font=('Arial', 20, 'bold'),
                bg='#FF6B6B', fg='white').pack(side='left', padx=20)
        
        canvas = tk.Canvas(self.root, bg='#FFF8E7', highlightthickness=0)
        scrollbar = ttk.Scrollbar(self.root, orient="vertical", command=canvas.yview)
        scrollable = tk.Frame(canvas, bg='#FFF8E7')
        
        scrollable.bind("<Configure>", lambda e: canvas.configure(scrollregion=canvas.bbox("all")))
        canvas.create_window((0, 0), window=scrollable, anchor="nw")
        canvas.configure(yscrollcommand=scrollbar.set)
        canvas.pack(side="left", fill="both", expand=True)
        scrollbar.pack(side="right", fill="y")
        
        culture_text = self.get_culture_info(location)
        culture_box = tk.Text(scrollable, height=5, wrap='word', bg='#FFE5B4', 
                              font=('Arial', 11), relief='solid', borderwidth=2)
        culture_box.insert('1.0', culture_text)
        culture_box.config(state='disabled')
        culture_box.pack(fill='x', pady=10, padx=10)
        
        tk.Label(scrollable, text="📖 РЕЦЕПТЫ-КВЕСТЫ", 
                font=('Arial', 16, 'bold'), bg='#FFF8E7', fg='#FF6B6B').pack(pady=10)
        
        recipes = self.get_recipes_for_location(location)
        for i, recipe in enumerate(recipes):
            recipe_frame = tk.Frame(scrollable, bg='#FFE5B4', relief='ridge', borderwidth=2)
            recipe_frame.pack(fill='x', pady=8, padx=10)
            
            is_completed = recipe in self.completed_recipes
            is_unlocked = recipe in self.unlocked_recipes.get(location, [])
            
            if not is_unlocked and i == 0:
                is_unlocked = True
                if recipe not in self.unlocked_recipes[location]:
                    self.unlocked_recipes[location].append(recipe)
            
            if is_completed:
                status = "✅"
                status_text = "Выполнено!"
                status_color = '#4CAF50'
            elif is_unlocked:
                status = "🔓"
                status_text = "Доступен!"
                status_color = '#FF9800'
            else:
                status = "🔒"
                status_text = "Заблокирован"
                status_color = '#999'
            
            tk.Label(recipe_frame, text=f"{status} {recipe}", 
                    font=('Arial', 12, 'bold'), bg='#FFE5B4').pack(side='left', padx=15, pady=12)
            
            if is_unlocked and not is_completed:
                btn = tk.Button(recipe_frame, text="▶ НАЧАТЬ КВЕСТ ▶", 
                               command=lambda r=recipe: self.start_quest(r),
                               bg='#4CAF50', fg='white', font=('Arial', 10, 'bold'), width=15)
                btn.pack(side='right', padx=10)
            elif is_completed:
                tk.Label(recipe_frame, text=status_text, font=('Arial', 11, 'bold'),
                        bg='#FFE5B4', fg=status_color).pack(side='right', padx=15)
            else:
                tk.Label(recipe_frame, text=f"Выполните: {recipes[i-1]}", 
                        font=('Arial', 9), bg='#FFE5B4', fg='#999').pack(side='right', padx=10)
    
