except ImportError:
    SOUND_ENABLED = False

class SoundManager:
    def __init__(self):
        self.enabled = SOUND_ENABLED
    def play(self, sound_name):
        if self.enabled:
            print(f"[Звук] {sound_name}")
    def toggle(self):
        self.enabled = not self.enabled
        return self.enabled

class ParticleEffect:
    """Класс для создания частиц"""
    def __init__(self, canvas, x, y, color, count=10):
        self.canvas = canvas
        self.particles = []
        for _ in range(count):
            angle = random.uniform(0, 2 * math.pi)
            speed = random.uniform(2, 8)
            vx = math.cos(angle) * speed
            vy = math.sin(angle) * speed
            particle = canvas.create_oval(x-3, y-3, x+3, y+3, fill=color, outline='')
            self.particles.append([particle, x, y, vx, vy, 30])
        self.animate()
    
    def animate(self):
        for p in self.particles[:]:
            p[1] += p[3]
            p[2] += p[4]
            p[5] -= 1
            self.canvas.coords(p[0], p[1]-2, p[2]-2, p[1]+2, p[2]+2)
            if p[5] <= 0:
                self.canvas.delete(p[0])
                self.particles.remove(p)
        if self.particles:
            self.canvas.after(30, self.animate)

class AnimatedButton(tk.Button):
    def __init__(self, master, text, command, bg='#FF6B6B', fg='white', **kwargs):
        super().__init__(master, text=text, command=command, bg=bg, fg=fg,
                        relief='raised', font=('Arial', 10, 'bold'))
        self.default_bg = bg
        self.hover_bg = self._lighten_color(bg)
        self.bind("<Enter>", self.on_enter)
        self.bind("<Leave>", self.on_leave)
        self.bind("<Button-1>", self.on_click_effect)
        self.configure(width=20, height=2)
    
    def _lighten_color(self, color):
        try:
            r = int(color[1:3], 16)
            g = int(color[3:5], 16)
            b = int(color[5:7], 16)
            r = min(255, int(r * 1.2))
            g = min(255, int(g * 1.2))
            b = min(255, int(b * 1.2))
            return f'#{r:02x}{g:02x}{b:02x}'
        except:
            return '#FF8787'
    
    def on_enter(self, e):
        self.config(bg=self.hover_bg)
    
    def on_leave(self, e):
        self.config(bg=self.default_bg)
    
    def on_click_effect(self, e):
        self.config(relief='sunken')
        self.after(100, lambda: self.config(relief='raised'))

class InteractiveCookingGame:
    """Интерактивная мини-игра приготовления с разными механиками"""
    def __init__(self, parent, action, on_complete):
        self.parent = parent
        self.action = action
        self.on_complete = on_complete
        self.progress = 0
        self.score = 0
        self.combo = 0
        self.timer_active = True
        self.timer = None
        self.combo_timer = None
        
    def create_game(self, container):
        self.container = container
        self.clear_container()
        
        # Добавляем красивый фон
        bg_frame = tk.Frame(self.container, bg='#FFF8E7')
        bg_frame.pack(fill='both', expand=True)
        
        if "тесто" in self.action.lower() or "замесить" in self.action.lower():
            self.create_dough_game(bg_frame)
        elif "пасту" in self.action.lower() or "сварить" in self.action.lower():
            self.create_pasta_game(bg_frame)
        elif "крем" in self.action.lower() or "взбить" in self.action.lower():
            self.create_whip_game(bg_frame)
        elif "тушить" in self.action.lower() or "соус" in self.action.lower():
            self.create_stew_game(bg_frame)
        elif "рис" in self.action.lower():
            self.create_rice_game(bg_frame)
        elif "нарезать" in self.action.lower():
            self.create_chopping_game(bg_frame)
        else:
            self.create_click_game(bg_frame)
    
    def clear_container(self):
        for widget in self.container.winfo_children():
            widget.destroy()
    
    def create_dough_game(self, parent):
