    def next_step(self):
        steps = self.get_recipe_steps(self.current_recipe)
        if self.current_step >= len(steps):
            self.complete_quest()
            return
        step = steps[self.current_step]
        if step["type"] == "find":
            self.show_find_game(step["items"])
        elif step["type"] == "cook":
            self.show_cook_game(step["action"])
        elif step["type"] == "quiz":
            self.show_quiz(step["question"], step["options"], step["correct"])
    
