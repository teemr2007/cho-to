    def create_chopping_game(self):
        """Игра нарезки - нужно кликать по движущимся объектам (замедленная)"""
        tk.Label(self.container, text="🔪 НАРЕЗАТЬ ИНГРЕДИЕНТЫ", 
                font=('Arial', 16, 'bold'), bg='#FFF8E7', fg='#FF6B6B').pack(pady=10)
        
        self.chop_count = 0
        self.chop_target = 12  # Увеличено с 10 до 12
        
        self.chop_canvas = tk.Canvas(self.container, width=450, height=250, bg='#FFE5B4')
        self.chop_canvas.pack(pady=10)
        
        # Создаем движущиеся ингредиенты
        self.veggies = []
        veg_names = ["🥕", "🍅", "🧅", "🥒", "🌶️", "🧄"]
        for i in range(4):  # Увеличено с 3 до 4 ингредиентов
            veg = {
                'id': self.chop_canvas.create_text(
                    random.randint(50, 400), random.randint(40, 210),
                    text=random.choice(veg_names), font=('Arial', 32), tags='veg'
                ),
                'x': random.randint(50, 400),
                'y': random.randint(40, 210),
                'dx': random.choice([-1, 1]) * random.randint(2, 4),  # Медленнее движение
                'dy': random.choice([-1, 1]) * random.randint(2, 4)
            }
            self.veggies.append(veg)
        
        self.chop_canvas.bind('<Button-1>', self.on_chop)
        
        self.chop_label = tk.Label(self.container, text=f"Нарезано: 0/{self.chop_target}", 
                                   font=('Arial', 12), bg='#FFF8E7')
        self.chop_label.pack()
        
        self.chop_progress = ttk.Progressbar(self.container, length=300, mode='determinate', 
                                            maximum=self.chop_target)
        self.chop_progress.pack(pady=10)
        
        self.move_veggies()
    
    def move_veggies(self):
        if self.chop_count >= self.chop_target:
            return
        for veg in self.veggies:
            # Двигаем каждый ингредиент
            veg['x'] += veg['dx']
            veg['y'] += veg['dy']
            
            # Отскок от границ
            if veg['x'] < 30 or veg['x'] > 420:
                veg['dx'] = -veg['dx']
                veg['x'] = max(30, min(420, veg['x']))
            if veg['y'] < 30 or veg['y'] > 220:
                veg['dy'] = -veg['dy']
                veg['y'] = max(30, min(220, veg['y']))
            
            self.chop_canvas.coords(veg['id'], veg['x'], veg['y'])
        
        # Замедленная анимация (50 FPS вместо 30)
        if self.chop_count < self.chop_target:
            self.parent.after(60, self.move_veggies)  # Увеличено с 30 до 60 мс
    
    def on_chop(self, event):
        items = self.chop_canvas.find_withtag('veg')
        for veg in self.veggies:
            coords = self.chop_canvas.coords(veg['id'])
            # Проверка попадания (увеличен радиус)
            if (coords[0] - 30 < event.x < coords[0] + 30 and 
                coords[1] - 30 < event.y < coords[1] + 30):
                # Анимация нарезки
                self.chop_canvas.delete(veg['id'])
                self.veggies.remove(veg)
                self.chop_count += 1
                self.chop_label.config(text=f"Нарезано: {self.chop_count}/{self.chop_target}")
                self.chop_progress['value'] = self.chop_count
                
                # Визуальный эффект
                chop_effect = self.chop_canvas.create_text(event.x, event.y, text="⚡", 
                                                          font=('Arial', 20), fill='gold')
                self.parent.after(200, lambda: self.chop_canvas.delete(chop_effect))
                
                # Создаем новый ингредиент
                if self.chop_count < self.chop_target:
                    veg_names = ["🥕", "🍅", "🧅", "🥒", "🌶️", "🧄"]
                    new_veg = {
                        'id': self.chop_canvas.create_text(
                            random.randint(50, 400), random.randint(40, 210),
                            text=random.choice(veg_names), font=('Arial', 32), tags='veg'
                        ),
                        'x': random.randint(50, 400),
                        'y': random.randint(40, 210),
                        'dx': random.choice([-1, 1]) * random.randint(2, 4),
                        'dy': random.choice([-1, 1]) * random.randint(2, 4)
                    }
                    self.veggies.append(new_veg)
                
                if self.chop_count >= self.chop_target:
                    self.complete_game()
                break
    
