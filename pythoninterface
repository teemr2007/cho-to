    def wash_rice(self):
        self.water_count += 1
        self.water_label.config(text=f"💧 Промывок: {self.water_count}/{self.water_target}")
        self.rice_progress['value'] = self.water_count
        
        water_y = 160 - (self.water_count * 14)
        if water_y < 50:
            water_y = 50
        self.rice_canvas.coords(self.water_level, 92, water_y, 258, 160)
        
        # Анимация
        self.water_btn.config(text="💦 ПРОМЫВАЮ... 💦", bg='#2196F3')
        ParticleEffect(self.rice_canvas, 175, 100, '#87CEEB', 10)
