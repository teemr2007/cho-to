    def add_exp(self, amount):
        self.player_exp += amount
        self.total_score += amount
        level_up = False
        while self.player_exp >= 100:
            self.player_level += 1
            self.player_exp -= 100
            level_up = True
        if level_up:
            self.show_level_up()
        self.save_game()
    
