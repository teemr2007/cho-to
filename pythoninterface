    def claim_daily_bonus(self):
        today = datetime.now().strftime("%Y-%m-%d")
        if self.last_daily_bonus != today:
            bonus = random.randint(50, 100)
            self.player_coins += bonus
            self.last_daily_bonus = today
            self.save_game()
            messagebox.showinfo("Ежедневный бонус!", f"Вы получили {bonus} 🪙 монет!")
        else:
            messagebox.showinfo("Бонус уже получен", "Вы уже получили сегодняшний бонус.")
    
