    def get_real_recipe(self, recipe):
        recipes = {
            "Пицца Маргарита": "🍕 ИНГРЕДИЕНТЫ:\n• Тесто для пиццы 250г\n• Томатный соус 100г\n• Моцарелла 200г\n• Свежий базилик\n\nПРИГОТОВЛЕНИЕ:\n1. Раскатать тесто\n2. Намазать томатным соусом\n3. Выложить моцареллу\n4. Запекать 10-12 мин при 250°C\n5. Украсить базиликом",
            "Паста Карбонара": "🍝 ИНГРЕДИЕНТЫ:\n• Спагетти 200г\n• Панчетта/бекон 100г\n• Яйца 2 шт\n• Пармезан 50г\n\nПРИГОТОВЛЕНИЕ:\n1. Обжарить панчетту\n2. Сварить спагетти al dente\n3. Смешать яйца с сыром\n4. Соединить все, добавив перец",
        }
        return recipes.get(recipe, "Приготовьте это блюдо дома, следуя классическому рецепту!")
    
    def open_collection(self):
        self.clear_window()
        
        header = tk.Frame(self.root, bg='#FF6B6B', height=80)
        header.pack(fill='x')
        header.pack_propagate(False)
        tk.Button(header, text="← Назад", command=self.setup_main_menu,
