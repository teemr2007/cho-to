        # Таймер для сброса комбо
        self.combo_timer = None
    
    def whip_action(self):
        self.whip_count += 1
        self.combo += 1
        
        # Анимация взбивания
        self.whip_canvas.coords(self.whip_text, 125 + random.randint(-10, 10), 
                                120 + random.randint(-10, 10))
        self.whip_canvas.after(100, lambda: self.whip_canvas.coords(self.whip_text, 125, 120))
        
        self.whip_label.config(text=f"Взбиваний: {self.whip_count}/{self.whip_target}")
        self.whip_progress['value'] = int(self.whip_count / self.whip_target * 100)
        
        if self.combo >= 3:
            self.combo_label.config(text=f"🔥 КОМБО x{self.combo}! 🔥")
            # Бонусный прогресс за комбо (каждые 3 клика +1)
            if self.combo % 3 == 0:
                self.whip_count += 1
                self.whip_label.config(text=f"Взбиваний: {self.whip_count}/{self.whip_target}")
                self.whip_progress['value'] = int(self.whip_count / self.whip_target * 100)
        
        # Сброс таймера комбо
        if self.combo_timer:
            self.parent.after_cancel(self.combo_timer)
        self.combo_timer = self.parent.after(2000, self.reset_combo)  # 2 секунды на комбо
        
        if self.whip_count >= self.whip_target:
            self.complete_game()
    
    def reset_combo(self):
        self.combo = 0
        self.combo_label.config(text="")
    
    def create_stew_game(self):
        """Игра тушения - нужно переворачивать ингредиенты (замедленная)"""
        tk.Label(self.container, text="🍲 ТУШИТЬ СОУС", 
                font=('Arial', 16, 'bold'), bg='#FFF8E7', fg='#FF6B6B').pack(pady=10)
        
        self.ingredients = ["🧅 Лук", "🥕 Морковь", "🍅 Томат", "🧄 Чеснок", "🌿 Травы", "🧂 Специи"]
        self.stewed = []
        
        self.stew_frame = tk.Frame(self.container, bg='#FFF8E7')
        self.stew_frame.pack(pady=10)
        
        self.stew_progress = ttk.Progressbar(self.container, length=300, mode='determinate', 
                                            maximum=len(self.ingredients))
        self.stew_progress.pack(pady=10)
        
        self.ingredient_buttons = []
        for ing in self.ingredients:
            btn = tk.Button(self.stew_frame, text=f"🔪 {ing}", command=lambda i=ing: self.stew_ingredient(i),
                           bg='#FFE5B4', font=('Arial', 11), width=18, height=2)
            btn.pack(pady=5)
            self.ingredient_buttons.append(btn)
        
        self.stew_label = tk.Label(self.container, text=f"Потушить: 0/{len(self.ingredients)}", 
                                   font=('Arial', 12), bg='#FFF8E7')
        self.stew_label.pack()
    
    def stew_ingredient(self, ingredient):
        if ingredient not in self.stewed:
            self.stewed.append(ingredient)
            self.stew_label.config(text=f"Потушить: {len(self.stewed)}/{len(self.ingredients)}")
            self.stew_progress['value'] = len(self.stewed)
            
            # Анимация - кнопка меняется с задержкой
            for btn in self.ingredient_buttons:
                if ingredient in btn['text']:
                    btn.config(text=f"✅ {ingredient}", bg='#4CAF50', state='disabled')
                    self.parent.after(500, lambda: None)  # Пауза для ощущения прогресса
            
            if len(self.stewed) >= len(self.ingredients):
                self.complete_game()
    
