                        font=('Arial', 10), bg='#FFE5B4', fg='green').pack(side='right', padx=10)
            else:
                prev_recipe = recipes[i-1] if i > 0 else None
                hint = f"Выполните: {prev_recipe}" if prev_recipe else "Выполните предыдущий"
