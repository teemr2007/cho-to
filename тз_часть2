   function renderBooks(filteredBooks) {
    bookGrid.innerHTML = filteredBooks.map(book => `
        <div class="book-card" data-title="${book.title.toLowerCase()}">
            <div class="book-cover">
                <img src="${book.coverUrl}" alt="${book.title}" loading="lazy" onerror="this.onerror=null; this.src='https://via.placeholder.com/200x300/2C2F2E/D4AF37?text=No+Cover'">
            </div>
            <div class="book-title">${book.title}</div>
            <div class="book-author">${book.author}</div>
            <a href="${book.shopUrl}" target="_blank" rel="noopener" class="book-link">Читать</a>
        </div>
    `).join('');
}

    function getCoverUrl(book) {
        if (book.isbn) {
            return `https://covers.openlibrary.org/b/isbn/${book.isbn}-L.jpg`;
        }
        return `https://via.placeholder.com/200x300/2C2F2E/D4AF37?text=${encodeURIComponent(book.title)}`;
    }

    function getSeriesName(series) {
        const names = {
            'Horus Heresy': 'Ересь Хоруса',
            'Indomitus': 'Эра Индомитус',
            'Space Marines': 'Космодесант',
            'Inquisition': 'Инквизиция',
            'Gaunt': 'Призраки Гаунта',
            'Other': 'Другое'
        };
        return names[series] || series;
    }

    function filterBooks() {
        const query = searchInput.value.toLowerCase();
        const series = seriesFilter.value;
        const filtered = books.filter(book => {
            const matchesTitle = book.title.toLowerCase().includes(query);
            const matchesSeries = series === 'all' || book.series === series;
            return matchesTitle && matchesSeries;
        });
        renderBooks(filtered);
    }

    searchInput.addEventListener('input', filterBooks);
    seriesFilter.addEventListener('change', filterBooks);
    
    renderBooks(books);
})();
