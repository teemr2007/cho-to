</style>

<script>
// Фильтрация таймлайна
const filterBtns = document.querySelectorAll('.filter-btn');
const timelineEvents = document.querySelectorAll('.timeline-event');

filterBtns.forEach(btn => {
    btn.addEventListener('click', function() {
        filterBtns.forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        const filter = this.dataset.filter;
        
        timelineEvents.forEach(event => {
            const factions = event.dataset.faction.split(' ');
            if (filter === 'all' || factions.includes(filter)) {
                event.style.display = 'inline-block';
            } else {
                event.style.display = 'none';
            }
        });
    });
});

// Горизонтальный скролл колесиком мыши
const timelineWrapper = document.querySelector('.timeline-wrapper');
if (timelineWrapper) {
    timelineWrapper.addEventListener('wheel', (e) => {
        if (e.deltaY !== 0) {
            e.preventDefault();
            timelineWrapper.scrollLeft += e.deltaY;
        }
    });
}
</script>

