    const filterSelect = document.getElementById('glossaryFilter');

    function renderGlossary(items) {
        if (!glossaryGrid) return;
        glossaryGrid.innerHTML = items.map(item => `
            <div class="glossary-card" data-name="${item.name.toLowerCase()}" data-url="${item.wikiUrl}">
                <div class="icon"><i class="${item.icon}"></i></div>
                <div class="category-tag">${item.category.toUpperCase()}</div>
                <h3>${item.name}</h3>
                <p>${item.desc}</p>
            </div>
        `).join('');

        // Добавляем обработчики клика на карточки
        document.querySelectorAll('.glossary-card').forEach(card => {
            card.addEventListener('click', function(e) {
                e.stopPropagation();
                const url = this.dataset.url;
                if (url) {
                    window.open(url, '_blank');
                } else {
                    alert('Страница на вики для этого понятия будет добавлена позже.');
                }
            });
        });
    }

    function filterGlossary() {
        const query = searchInput?.value.toLowerCase() || '';
        const category = filterSelect?.value || 'all';
        const filtered = glossaryData.filter(item => {
            const matchesQuery = item.name.toLowerCase().includes(query);
            const matchesCategory = category === 'all' || item.category === category;
            return matchesQuery && matchesCategory;
        });
        renderGlossary(filtered);
    }

    if (searchInput && filterSelect) {
        searchInput.addEventListener('input', filterGlossary);
        filterSelect.addEventListener('change', filterGlossary);
        renderGlossary(glossaryData);
    }
})();
</script>

    <!-- ЛАЙТБОКС -->
    <div class="lightbox" id="lightbox" onclick="closeLightbox()">
        <span class="lightbox-close">&times;</span>
        <img id="lightbox-img" src="" alt="">
    </div>

    <!-- ФУТЕР -->
    <footer class="footer-modern">
        <div class="container">
            <p>✦ IN THE GRIM DARKNESS OF THE FAR FUTURE THERE IS ONLY WAR ✦</p>
            <p style="margin-top: 20px;">© 2026 <span>CODEX IMPERIALIS</span>. Warhammer 40,000 и связанные логотипы являются товарными знаками Games Workshop Limited.</p>
        </div>
    </footer>

    <!-- МУЗЫКАЛЬНАЯ КНОПКА -->
    <div class="music-control-modern" id="musicToggle">
        <i class="fas fa-volume-mute"></i>
    </div>

    <audio id="bgMusic" loop preload="auto">
        <source src="https://cdn.freesound.org/previews/648/648660_11943129-lq.mp3" type="audio/mp3">
        <source src="https://cdn.freesound.org/previews/672/672251_13635082-lq.mp3" type="audio/mp3">
    </audio>

    <script>
        (function() {
            // Создание звёзд
            function createStars() {
                const starsContainer = document.getElementById('stars');
                if (!starsContainer) return;
                
                for (let i = 0; i < 200; i++) {
                    const star = document.createElement('div');
                    star.className = 'star';
                    
                    const size = Math.random() * 2 + 1;
                    const left = Math.random() * 100;
                    const top = Math.random() * 100;
                    const duration = Math.random() * 3 + 2;
                    const opacityStart = Math.random() * 0.3 + 0.2;
                    const opacityEnd = Math.random() * 0.8 + 0.2;
                    
                    star.style.width = size + 'px';
                    star.style.height = size + 'px';
                    star.style.left = left + '%';
                    star.style.top = top + '%';
                    star.style.setProperty('--duration', duration + 's');
                    star.style.setProperty('--opacity-start', opacityStart);
                    star.style.setProperty('--opacity-end', opacityEnd);
                    
                    starsContainer.appendChild(star);
                }
            }

            // Создание частиц
            function createParticles() {
                const particlesContainer = document.getElementById('particles');
                if (!particlesContainer) return;
                
                for (let i = 0; i < 30; i++) {
                    const particle = document.createElement('div');
                    particle.className = 'particle';
                    
                    const left = Math.random() * 100;
                    const duration = Math.random() * 20 + 15;
                    const delay = Math.random() * 10;
                    
                    particle.style.left = left + '%';
                    particle.style.animationDuration = duration + 's';
                    particle.style.animationDelay = delay + 's';
                    
                    particlesContainer.appendChild(particle);
                }
            }

            // Переключение страниц
            const tabs = document.querySelectorAll('.menu-tab');
            const pages = document.querySelectorAll('.page-container, .map-page');
            const homePage = document.getElementById('home-page');
            const mapPage = document.getElementById('map-page');
            const body = document.body;

            window.switchToPage = function(pageId) {
                if (pageId === 'home') {
                    homePage.style.display = 'block';
                    if (mapPage) mapPage.style.display = 'none';
                    pages.forEach(p => p.classList.remove('active-page'));
                    body.setAttribute('data-page', 'home');
                    body.setAttribute('data-theme', 'imperium');
                } else if (pageId === 'map') {
                    homePage.style.display = 'none';
                    if (mapPage) {
                        mapPage.style.display = 'block';
                        mapPage.classList.add('active-page');
                    }
                    pages.forEach(p => {
                        if (p !== mapPage) p.classList.remove('active-page');
                    });
                    body.setAttribute('data-page', 'map');
                    body.setAttribute('data-theme', 'imperium');
                } else {
                    homePage.style.display = 'none';
                    if (mapPage) mapPage.style.display = 'none';
                    
                    // Убираем активный класс со всех страниц
                    pages.forEach(p => p.classList.remove('active-page'));
                    
                    // Активируем нужную страницу
                    const targetPage = document.getElementById(pageId);
                    if (targetPage) {
                        targetPage.classList.add('active-page');
                    }
                    else if (pageId === 'glossary') {
    homePage.style.display = 'none';
    if (mapPage) mapPage.style.display = 'none';
    pages.forEach(p => p.classList.remove('active-page'));
    const glossaryPage = document.getElementById('page-glossary');
    if (glossaryPage) glossaryPage.classList.add('active-page');
    body.setAttribute('data-page', 'glossary');
    body.setAttribute('data-theme', 'imperium');
}
                    
                    // Установка темы в зависимости от страницы
                    const themeMap = {
                        'page1': 'imperium',
                        'page2': 'chaos',
                        'page3': 'eldar',
                        'page4': 'ork',
                        'page5': 'necron',
                        'page6': 'tyranid',
                        'page7': 'tau',
                        'page8': 'votann',
                        'page9': 'imperium',
                        'page10': 'imperium'
                    };
                    if (themeMap[pageId]) {
                        body.setAttribute('data-theme', themeMap[pageId]);
                    }
                    body.setAttribute('data-page', 'faction');
                }
                
                // Обновление активной вкладки в меню
                tabs.forEach(t => t.classList.remove('active-tab'));
                const activeTab = Array.from(tabs).find(tab => tab.getAttribute('data-page') === pageId);
                if (activeTab) activeTab.classList.add('active-tab');
                
                window.scrollTo({ top: 0, behavior: 'smooth' });
                
            };

            tabs.forEach(tab => {
                tab.addEventListener('click', () => {
                    const pageId = tab.getAttribute('data-page');
                    switchToPage(pageId);
                });
            });

            // Колесо фракций
            window.updateCenter = function(name, desc) {
                document.getElementById('faction-name').innerText = name;
                document.getElementById('faction-desc').innerText = desc;
            };

            // Музыка
            const music = document.getElementById('bgMusic');
            const toggleBtn = document.getElementById('musicToggle');
            let musicPlaying = false;
            music.volume = 0.3;

            function attemptAutoPlay() {
                music.play().then(() => {
                    musicPlaying = true;
                    toggleBtn.innerHTML = '<i class="fas fa-volume-up"></i>';
                }).catch(() => {
                    musicPlaying = false;
                    toggleBtn.innerHTML = '<i class="fas fa-volume-mute"></i>';
                });
            }
            attemptAutoPlay();

            toggleBtn.addEventListener('click', () => {
                if (musicPlaying) {
                    music.pause();
                    toggleBtn.innerHTML = '<i class="fas fa-volume-mute"></i>';
                    musicPlaying = false;
                } else {
                    music.play().then(() => {
                        toggleBtn.innerHTML = '<i class="fas fa-volume-up"></i>';
                        musicPlaying = true;
                    }).catch(() => {
                        alert('Не удалось воспроизвести аудио.');
                    });
                }
            });

            // Функции для карты
            let scale = 1;
            let panX = 0;
            let panY = 0;
            let isDragging = false;
            let startX, startY;
            
            const map = document.getElementById('galaxyMap');
            
            window.zoomIn = function() {
                scale = Math.min(scale + 0.1, 2);
                applyTransform();
            };
            
            window.zoomOut = function() {
                scale = Math.max(scale - 0.1, 0.5);
                applyTransform();
            };
            
            window.resetMap = function() {
                scale = 1;
                panX = 0;
                panY = 0;
                applyTransform();
            };
            
            function applyTransform() {
                if (map) {
                    map.style.transform = `scale(${scale}) translate(${panX}px, ${panY}px)`;
                    map.style.transformOrigin = 'center';
                }
            }
            
            if (map) {
                map.addEventListener('mousedown', (e) => {
                    isDragging = true;
                    startX = e.clientX - panX;
                    startY = e.clientY - panY;
                    map.style.cursor = 'grabbing';
                });
                
                window.addEventListener('mousemove', (e) => {
                    if (!isDragging) return;
                    e.preventDefault();
                    panX = e.clientX - startX;
                    panY = e.clientY - startY;
                    applyTransform();
                });
                
                window.addEventListener('mouseup', () => {
                    isDragging = false;
                    map.style.cursor = 'grab';
                });
            }
            
            window.showWorldInfo = function(worldId) {
                const worldData = document.getElementById(worldId);
                if (!worldData) return;
                
                const title = worldData.getAttribute('data-title');
                const faction = worldData.getAttribute('data-faction');
                const coord = worldData.getAttribute('data-coord');
                const desc = worldData.getAttribute('data-desc');
                
                let factionColor;
                switch(faction) {
                    case 'Империум': factionColor = '#d5cb05'; break;
                    case 'Хаос': factionColor = '#a61d1d'; break;
                    case 'Эльдары': factionColor = '#751099'; break;
                    case 'Орки': factionColor = '#199500'; break;
                    case 'Некроны': factionColor = '#163118'; break;
                    case 'Тираниды': factionColor = '#d8559f'; break;
                    case 'Тау': factionColor = '#07ad97'; break;
                    case 'Лиги Воттан': factionColor = '#bd7518'; break;
                    default: factionColor = '#808080';
                }
                
                const worldDetails = document.getElementById('worldDetails');
                if (worldDetails) {
                    worldDetails.innerHTML = `
                        <div class="world-card">
                            <h3>${title}</h3>
                            <div class="faction-tag" style="background: ${factionColor}20; color: ${factionColor};">${faction}</div>
                            <div class="coord">${coord}</div>
                            <p class="desc">${desc}</p>
                        </div>
                    `;
                }
                
                const titleElement = document.getElementById('selectedWorldTitle');
                if (titleElement) titleElement.innerText = title;
            };

            // Фильтр таймлайна
            const filterBtns = document.querySelectorAll('.filter-btn');
            filterBtns.forEach(btn => {
                btn.addEventListener('click', function() {
                    filterBtns.forEach(b => b.classList.remove('active'));
                    this.classList.add('active');
                    const filter = this.dataset.filter;
                    const events = document.querySelectorAll('.timeline-event');
                    events.forEach(event => {
                        if (filter === 'all' || event.dataset.faction === filter) {
                            event.style.display = 'inline-block';
                        } else {
                            event.style.display = 'none';
                        }
                    });
                });
            });

            // Поиск в библиотеке
            const searchInput = document.getElementById('librarySearch');
            if (searchInput) {
                searchInput.addEventListener('input', function() {
                    const query = this.value.toLowerCase();
                    const books = document.querySelectorAll('.book-card');
                    books.forEach(book => {
                        const title = book.dataset.title.toLowerCase();
                        if (title.includes(query)) {
                            book.style.display = 'block';
                        } else {
                            book.style.display = 'none';
                        }
                    });
                });
            }

            // Лайтбокс
            window.openLightbox = function(element) {
                const img = element.querySelector('img');
                const lightbox = document.getElementById('lightbox');
                const lightboxImg = document.getElementById('lightbox-img');
                lightboxImg.src = img.src;
                lightbox.classList.add('active');
            };

            window.closeLightbox = function() {
                document.getElementById('lightbox').classList.remove('active');
            };

            // Инициализация
            createStars();
            createParticles();
            resetMap();
            
            // Показать главную страницу по умолчанию
            homePage.style.display = 'block';
            if (mapPage) mapPage.style.display = 'none';
            body.setAttribute('data-page', 'home');
            body.setAttribute('data-theme', 'imperium');
            
            // Показать Терру на карте по умолчанию
            setTimeout(() => showWorldInfo('terra'), 100);
        })();
    </script>
</body>
