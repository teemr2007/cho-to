<script>
// ========== МАСШТАБИРОВАНИЕ КАРТЫ ==========
let scale = 1;
let panX = 0;
let panY = 0;
let isDragging = false;
let startX, startY;
const mapContainer = document.querySelector('.galaxy-map-container');
const map = document.getElementById('galaxyMap');

function applyTransform() {
    if (map) {
        map.style.transform = `scale(${scale}) translate(${panX / scale}px, ${panY / scale}px)`;
    }
}

window.zoomIn = function() {
    scale = Math.min(scale + 0.15, 3);
    applyTransform();
};

window.zoomOut = function() {
    scale = Math.max(scale - 0.15, 0.4);
    applyTransform();
};

window.resetMap = function() {
    scale = 1;
    panX = 0;
    panY = 0;
    applyTransform();
};

if (mapContainer) {
    mapContainer.addEventListener('mousedown', (e) => {
        if (e.target.closest('.world-marker')) return;
        isDragging = true;
        startX = e.clientX - panX;
        startY = e.clientY - panY;
        mapContainer.style.cursor = 'grabbing';
        e.preventDefault();
    });
    
    window.addEventListener('mousemove', (e) => {
        if (!isDragging) return;
        panX = e.clientX - startX;
        panY = e.clientY - startY;
        const maxPanX = 500 * scale;
        const maxPanY = 500 * scale;
        panX = Math.min(Math.max(panX, -maxPanX), maxPanX);
        panY = Math.min(Math.max(panY, -maxPanY), maxPanY);
        applyTransform();
    });
    
    window.addEventListener('mouseup', () => {
        isDragging = false;
        if (mapContainer) mapContainer.style.cursor = 'grab';
    });
    
    mapContainer.addEventListener('wheel', (e) => {
        e.preventDefault();
        const delta = e.deltaY > 0 ? -0.1 : 0.1;
        const newScale = Math.min(Math.max(scale + delta, 0.4), 3);
        if (newScale !== scale) {
            const rect = mapContainer.getBoundingClientRect();
            const mouseX = e.clientX - rect.left;
            const mouseY = e.clientY - rect.top;
            const scaleFactor = newScale / scale;
            panX = mouseX - (mouseX - panX) * scaleFactor;
            panY = mouseY - (mouseY - panY) * scaleFactor;
            scale = newScale;
            applyTransform();
        }
    });
}

// ========== ТУЛТИП ПРИ НАВЕДЕНИИ ==========
const markers = document.querySelectorAll('.world-marker');
const tooltip = document.getElementById('worldTooltip');
let tooltipTimeout;

markers.forEach(marker => {
    marker.addEventListener('mouseenter', (e) => {
        const title = marker.getAttribute('data-title') || marker.querySelector('.marker-label')?.innerText || 'Неизвестный мир';
        const faction = marker.getAttribute('data-faction') || '';
        const desc = marker.getAttribute('data-desc') || 'Нет описания';
        const image = marker.getAttribute('data-image') || 'https://via.placeholder.com/200x150/2C2F2E/D4AF37?text=No+Image';
        
        document.getElementById('tooltipImage').querySelector('img').src = image;
        document.getElementById('tooltipTitle').innerText = title;
        
        let factionColor = '#a0a8b0';
        if (marker.classList.contains('marker-imperium')) factionColor = '#d5cb05';
        else if (marker.classList.contains('marker-chaos')) factionColor = '#a61d1d';
        else if (marker.classList.contains('marker-eldar')) factionColor = '#751099';
        else if (marker.classList.contains('marker-ork')) factionColor = '#199500';
        else if (marker.classList.contains('marker-necron')) factionColor = '#163118';
        else if (marker.classList.contains('marker-tyranid')) factionColor = '#d8559f';
        else if (marker.classList.contains('marker-tau')) factionColor = '#07ad97';
        else if (marker.classList.contains('marker-votann')) factionColor = '#bd7518';
        
        document.getElementById('tooltipFaction').innerHTML = `<span style="color: ${factionColor}">${faction}</span>`;
        document.getElementById('tooltipDesc').innerText = desc;
        
        const rect = marker.getBoundingClientRect();
        tooltip.style.display = 'block';
        tooltip.style.left = (rect.right + 15) + 'px';
        tooltip.style.top = (rect.top - 20) + 'px';
        
        const tooltipRect = tooltip.getBoundingClientRect();
        if (tooltipRect.right > window.innerWidth) {
            tooltip.style.left = (rect.left - tooltipRect.width - 15) + 'px';
        }
        if (tooltipRect.bottom > window.innerHeight) {
            tooltip.style.top = (rect.bottom - tooltipRect.height) + 'px';
        }
        
        clearTimeout(tooltipTimeout);
    });
    
    marker.addEventListener('mouseleave', () => {
        tooltipTimeout = setTimeout(() => {
            tooltip.style.display = 'none';
        }, 200);
    });
});

// Инициализация
applyTransform();
</script>



