<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>++ CODEX IMPERIALIS · WARHAMMER 40k ++</title>
    <!-- Font Awesome для иконок -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Шрифты -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700;900&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
        <style>
        /* ========== СБРОС И БАЗОВЫЕ СТИЛИ ========== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Montserrat', sans-serif;
            background: #0a0504;
            background-image: 
                repeating-linear-gradient(45deg, rgba(40, 20, 10, 0.3) 0px, rgba(40, 20, 10, 0.3) 2px, transparent 2px, transparent 8px),
                repeating-linear-gradient(135deg, rgba(60, 30, 15, 0.2) 0px, rgba(60, 30, 15, 0.2) 4px, transparent 4px, transparent 12px),
                radial-gradient(circle at 30% 40%, #2a1a0f 0%, #0a0603 80%);
            color: #e0e4e8;
            line-height: 1.6;
            min-height: 100vh;
            transition: background 0.5s ease, color 0.3s ease;
            position: relative;
            overflow-x: hidden;
        }
     /* Контейнер карты с ограничением области просмотра */
.galaxy-map-container {
    cursor: grab;
    position: relative;
    background: radial-gradient(ellipse at center, #1a2a3a 0%, #0a121a 100%);
}

.galaxy-map-container:active {
    cursor: grabbing;
}

/* Сама карта, которая масштабируется */
.galaxy-map {
    position: relative;
    width: 100%;
    height: 100%;
    background: transparent;
    transition: transform 0.2s cubic-bezier(0.2, 0.9, 0.4, 1.1);
}

/* Адаптация маркеров при масштабировании - они масштабируются вместе с картой */
.world-marker {
    position: absolute;
    width: 30px;
    height: 30px;
    transform: translate(-50%, -50%);
    cursor: pointer;
    transition: transform 0.2s ease;
    z-index: 10;
}

/* При наведении на маркер увеличиваем его относительно текущего масштаба */
.world-marker:hover {
    transform: translate(-50%, -50%) scale(1.2);
    filter: drop-shadow(0 0 20px currentColor);
    z-index: 100;
}
/* Анимированное ядро галактики */
.galactic-core-animated {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 200px;
    height: 200px;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, #ffcc88 0%, #ffaa66 30%, #886644 60%, transparent 80%);
    border-radius: 50%;
    filter: blur(20px);
    animation: corePulseReal 4s ease-in-out infinite;
    pointer-events: none;
    z-index: 1;
}

@keyframes corePulseReal {
    0%, 100% { opacity: 0.5; transform: translate(-50%, -50%) scale(1); filter: blur(20px); }
    50% { opacity: 0.8; transform: translate(-50%, -50%) scale(1.1); filter: blur(25px); }
}

        /* ========== ФОНОВЫЕ ЭФФЕКТЫ WARHAMMER 40k ========== */
        
        /* Варп-туманность (движущаяся) */
        .warp-nebula {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: 
                radial-gradient(circle at 20% 30%, rgba(180, 70, 150, 0.15) 0%, transparent 40%),
                radial-gradient(circle at 80% 70%, rgba(70, 150, 200, 0.15) 0%, transparent 40%),
                radial-gradient(circle at 40% 80%, rgba(150, 50, 50, 0.12) 0%, transparent 50%),
                radial-gradient(circle at 70% 20%, rgba(200, 150, 50, 0.12) 0%, transparent 50%);
            filter: blur(40px);
            pointer-events: none;
            z-index: -5;
            animation: warpDrift 30s ease-in-out infinite alternate;
            mix-blend-mode: screen;
        }

        @keyframes warpDrift {
            0% { transform: scale(1) rotate(0deg); opacity: 0.6; filter: blur(40px); }
            50% { transform: scale(1.2) rotate(5deg); opacity: 0.9; filter: blur(30px); }
            100% { transform: scale(0.9) rotate(-5deg); opacity: 0.7; filter: blur(50px); }
        }

        /* Эффект "свечения варпа" (пульсирующие пятна) */
        .warp-glow {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 50% 50%, rgba(150, 50, 200, 0.1) 0%, transparent 60%),
                        radial-gradient(circle at 80% 20%, rgba(200, 100, 50, 0.1) 0%, transparent 50%),
                        radial-gradient(circle at 20% 80%, rgba(50, 100, 200, 0.1) 0%, transparent 50%);
            filter: blur(60px);
            pointer-events: none;
            z-index: -5;
            animation: glowPulse 15s ease-in-out infinite alternate;
            mix-blend-mode: overlay;
        }

        @keyframes glowPulse {
            0% { opacity: 0.3; filter: blur(60px); }
            100% { opacity: 0.7; filter: blur(80px); }
        }

        /* Варп-разряды (молнии) */
        .warp-lightning {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: repeating-linear-gradient(
                90deg,
                transparent 0px,
                transparent 100px,
                rgba(180, 70, 200, 0.03) 100px,
                rgba(180, 70, 200, 0.03) 110px,
                transparent 110px,
                transparent 210px,
                rgba(70, 150, 255, 0.03) 210px,
                rgba(70, 150, 255, 0.03) 220px,
                transparent 220px
            );
            pointer-events: none;
            z-index: -4;
            animation: lightningMove 8s linear infinite;
        }

        @keyframes lightningMove {
            0% { transform: translateX(-100px) rotate(0deg); opacity: 0.3; }
            50% { transform: translateX(100px) rotate(2deg); opacity: 0.7; }
            100% { transform: translateX(-100px) rotate(0deg); opacity: 0.3; }
        }

        /* Эффект "искажения реальности" (рябь) */
        .warp-ripple {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: repeating-radial-gradient(
                circle at 30% 40%,
                transparent 0px,
                transparent 50px,
                rgba(200, 100, 255, 0.02) 50px,
                rgba(200, 100, 255, 0.02) 55px,
                transparent 55px,
                transparent 105px,
                rgba(100, 200, 255, 0.02) 105px,
                rgba(100, 200, 255, 0.02) 110px,
                transparent 110px
            );
            pointer-events: none;
            z-index: -3;
            animation: ripplePulse 12s ease-in-out infinite;
        }

        @keyframes ripplePulse {
            0% { transform: scale(1); opacity: 0.3; }
            50% { transform: scale(1.1); opacity: 0.7; }
            100% { transform: scale(1); opacity: 0.3; }
        }

        /* Имперский орел (едва заметный водяной знак) */
        .imperial-aquila {
            position: fixed;
            bottom: 20px;
            left: 20px;
            width: 150px;
            height: 150px;
            background: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" opacity="0.1"><path d="M20,50 L35,30 L50,40 L65,30 L80,50 L65,70 L50,60 L35,70 L20,50" fill="none" stroke="%23D4AF37" stroke-width="2"/><circle cx="50" cy="45" r="5" fill="%23D4AF37"/></svg>');
            background-size: contain;
            background-repeat: no-repeat;
            pointer-events: none;
            z-index: -2;
            animation: aquilaGlow 10s ease-in-out infinite;
        }

        @keyframes aquilaGlow {
            0%, 100% { opacity: 0.1; transform: scale(1); }
            50% { opacity: 0.2; transform: scale(1.05); }
        }

        /* Символы Хаоса (плавно появляются и исчезают) */
        .chaos-symbols {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: repeating-linear-gradient(
                45deg,
                transparent 0px,
                transparent 200px,
                rgba(180, 50, 50, 0.02) 200px,
                rgba(180, 50, 50, 0.02) 220px,
                transparent 220px,
                transparent 420px,
                rgba(50, 50, 180, 0.02) 420px,
                rgba(50, 50, 180, 0.02) 440px,
                transparent 440px
            );
            pointer-events: none;
            z-index: -3;
            animation: symbolsFade 15s ease-in-out infinite;
        }

        @keyframes symbolsFade {
            0%, 100% { opacity: 0.2; }
            50% { opacity: 0.5; }
        }

        /* Парящие "души" (маленькие точки, имитирующие души в варпе) */
        .warp-souls {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: -2;
        }

        .soul {
            position: absolute;
            width: 3px;
            height: 3px;
            background: rgba(212, 175, 55, 0.4);
            border-radius: 50%;
            box-shadow: 0 0 10px rgba(212, 175, 55, 0.6);
            animation: soulFloat linear infinite;
        }

        @keyframes soulFloat {
            0% {
                transform: translateY(100vh) translateX(0) scale(1);
                opacity: 0;
            }
            10% {
                opacity: 0.8;
            }
            90% {
                opacity: 0.8;
            }
            100% {
                transform: translateY(-100vh) translateX(100px) scale(0.5);
                opacity: 0;
            }
        }

        /* Звёздное поле с мерцанием */
        .stars {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: -6;
        }

        .star {
            position: absolute;
            background: white;
            border-radius: 50%;
            animation: twinkle var(--duration) ease-in-out infinite;
        }

        @keyframes twinkle {
            0%, 100% { opacity: var(--opacity-start, 0.3); }
            50% { opacity: var(--opacity-end, 1); }
        }

        /* Мелкие частицы */
        .particles {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: -1;
        }

        .particle {
            position: absolute;
            width: 2px;
            height: 2px;
            background: rgba(212, 175, 55, 0.3);
            border-radius: 50%;
            box-shadow: 0 0 10px currentColor;
            animation: floatParticle linear infinite;
        }

        @keyframes floatParticle {
            from {
                transform: translateY(100vh) translateX(0);
                opacity: 0;
            }
            to {
                transform: translateY(-100vh) translateX(100px);
                opacity: 0;
            }
        }

        /* Тень и пульсация */
        .shadow-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(ellipse at 50% 50%, transparent 0%, rgba(0,0,0,0.7) 100%);
            pointer-events: none;
            z-index: -1;
            animation: shadowPulse 8s ease-in-out infinite;
        }

        @keyframes shadowPulse {
            0%, 100% { opacity: 0.5; }
            50% { opacity: 0.8; }
        }

        /* Световые лучи */
        .light-rays {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: repeating-linear-gradient(
                45deg,
                transparent 0px,
                transparent 20px,
                rgba(212, 175, 55, 0.02) 20px,
                rgba(212, 175, 55, 0.02) 40px
            );
            pointer-events: none;
            z-index: -1;
            animation: raysMove 15s linear infinite;
        }

        @keyframes raysMove {
            0% { background-position: 0 0; }
            100% { background-position: 200px 200px; }
        }

        /* Плавающие орбы */
        .glowing-orb {
            position: fixed;
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(212, 175, 55, 0.15) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
            z-index: -2;
            animation: orbFloat 20s ease-in-out infinite;
        }

        .glowing-orb:nth-child(1) {
            top: 10%;
            left: 10%;
            animation: orbFloat 20s ease-in-out infinite;
        }

        .glowing-orb:nth-child(2) {
            bottom: 10%;
            right: 10%;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(139, 0, 0, 0.1) 0%, transparent 70%);
            animation: orbFloat 25s ease-in-out infinite reverse;
        }

        @keyframes orbFloat {
            0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.3; }
            33% { transform: translate(30px, -30px) scale(1.1); opacity: 0.5; }
            66% { transform: translate(-20px, 20px) scale(0.9); opacity: 0.4; }
        }

        /* Мерцание */
        .flicker-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.02);
            pointer-events: none;
            z-index: -1;
            animation: flicker 4s step-end infinite;
        }

        @keyframes flicker {
            0%, 100% { opacity: 0; }
            25% { opacity: 0.1; }
            50% { opacity: 0; }
            75% { opacity: 0.05; }
        }

        /* ========== ТЕМЫ ФРАКЦИЙ ========== */
        body[data-theme="imperium"] {
            background: linear-gradient(135deg, #0b141f, #030a12);
            color: #c9d9f0;
        }

        body[data-theme="chaos"] {
            background: linear-gradient(135deg, #1f0c0c, #120606);
            color: #f0c9c9;
        }

        body[data-theme="eldar"] {
            background: linear-gradient(135deg, #0c1f17, #06120e);
            color: #c9f0dd;
        }

        body[data-theme="ork"] {
            background: linear-gradient(135deg, #141f0c, #0c1206);
            color: #ddf0c9;
        }

        body[data-theme="necron"] {
            background: linear-gradient(135deg, #0c111f, #060812);
            color: #c9d0f0;
        }

        body[data-theme="tyranid"] {
            background: linear-gradient(135deg, #1f0c14, #12060a);
            color: #f0c9da;
        }

        body[data-theme="tau"] {
            background: linear-gradient(135deg, #1f1a0c, #121006);
            color: #f0e6c9;
        }

        body[data-theme="votann"] {
            background: linear-gradient(135deg, #1f130c, #120b06);
            color: #f0dbc9;
        }

        /* ========== ТИПОГРАФИКА ========== */
        h1, h2, h3, h4, h5, h6 {
            font-family: 'Cinzel', serif;
            font-weight: 700;
            letter-spacing: 1px;
            color: #D4AF37;
            margin-bottom: 1.5rem;
            position: relative;
        }

        h1 { 
            font-size: clamp(2rem, 5vw, 3.5rem);
            text-transform: uppercase;
            text-shadow: 0 0 20px rgba(212, 175, 55, 0.3);
        }

        h2 {
            font-size: clamp(1.8rem, 4vw, 2.5rem);
            display: inline-block;
        }

        h2::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 0;
            width: 60px;
            height: 3px;
            background: linear-gradient(90deg, #D4AF37, #8B0000);
            border-radius: 2px;
        }

        h3 {
            font-size: clamp(1.3rem, 3vw, 1.8rem);
            color: #e0b354;
        }

        a {
            color: #D4AF37;
            text-decoration: none;
            transition: all 0.3s ease;
            position: relative;
        }

        a:not(.btn-gold):not(.btn-outline)::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 0;
            width: 0;
            height: 1px;
            background: #8B0000;
            transition: width 0.3s ease;
        }

        a:not(.btn-gold):not(.btn-outline):hover::after {
            width: 100%;
        }

        /* ========== КНОПКИ ========== */
        .btn-gold, .btn-outline {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            padding: 12px 30px;
            font-family: 'Cinzel', serif;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 2px;
            border: none;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            border-radius: 4px;
            position: relative;
            overflow: hidden;
        }

        .btn-gold::before, .btn-outline::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.2);
            transform: translate(-50%, -50%);
            transition: width 0.6s, height 0.6s;
        }

        .btn-gold:hover::before, .btn-outline:hover::before {
            width: 300px;
            height: 300px;
        }

        .btn-gold {
            background: linear-gradient(135deg, #D4AF37, #9A7D0C);
            color: #0A0C0B;
            box-shadow: 0 4px 15px rgba(212, 175, 55, 0.3);
        }

        .btn-gold:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(212, 175, 55, 0.4);
        }

        .btn-outline {
            background: transparent;
            color: #D4AF37;
            border: 2px solid #D4AF37;
            box-shadow: 0 4px 15px transparent;
        }

        .btn-outline:hover {
            background: rgba(212, 175, 55, 0.1);
            border-color: #8B0000;
            color: #8B0000;
        }

        /* ========== КОНТЕЙНЕР ========== */
        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 30px;
        }

        /* ========== ШАПКА И МЕНЮ ========== */
        .header {
            padding: 20px 0;
            border-bottom: 1px solid rgba(212, 175, 55, 0.2);
            backdrop-filter: blur(10px);
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(10, 12, 14, 0.8);
        }

        .header-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
        }

        .logo {
            font-family: 'Cinzel', serif;
            font-size: 1.8rem;
            font-weight: 900;
            color: #D4AF37;
            text-transform: uppercase;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .logo i {
            color: #8B0000;
            font-size: 2rem;
        }

        .main-menu {
            display: flex;
            flex-wrap: wrap;
            gap: 5px;
            background: rgba(20, 25, 30, 0.5);
            padding: 10px;
            border-radius: 12px;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(212, 175, 55, 0.2);
        }

        .menu-tab {
            padding: 12px 24px;
            font-family: 'Cinzel', serif;
            font-weight: 600;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            cursor: pointer;
            transition: all 0.3s ease;
            border-radius: 8px;
            color: #a0a8b0;
            background: transparent;
            border: 1px solid transparent;
        }

        .menu-tab:hover {
            background: rgba(212, 175, 55, 0.1);
            color: #D4AF37;
            border-color: rgba(212, 175, 55, 0.3);
        }

        .menu-tab.active-tab {
            background: linear-gradient(135deg, #D4AF37, #9A7D0C);
            color: #0A0C0B;
            box-shadow: 0 4px 15px rgba(212, 175, 55, 0.3);
        }

        /* ========== КАРТОЧКИ ========== */
        .cards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
            margin: 40px 0;
        }

        .card {
            background: rgba(20, 25, 30, 0.7);
            border: 1px solid rgba(212, 175, 55, 0.2);
            padding: 30px;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
            border-radius: 16px;
            backdrop-filter: blur(10px);
        }

        .card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, #D4AF37, #8B0000);
            transform: translateX(-100%);
            transition: transform 0.3s ease;
        }

        .card:hover::before {
            transform: translateX(0);
        }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 30px rgba(0, 0, 0, 0.4);
            border-color: rgba(212, 175, 55, 0.4);
        }

        .card i {
            font-size: 2.5rem;
            color: #D4AF37;
            margin-bottom: 20px;
        }

        /* ========== КОЛЕСО ФРАКЦИЙ ========== */
        .faction-wheel-modern {
            display: flex;
            justify-content: center;
            align-items: center;
            position: relative;
            height: 450px;
            margin: 60px 0;
        }

        .center-faction-modern {
            width: 180px;
            height: 180px;
            background: rgba(20, 25, 30, 0.9);
            border: 3px solid #D4AF37;
            border-radius: 50%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 20px;
            box-shadow: 0 0 40px rgba(212, 175, 55, 0.3);
            backdrop-filter: blur(10px);
            animation: pulseCenter 3s ease-in-out infinite;
        }

        @keyframes pulseCenter {
            0%, 100% { box-shadow: 0 0 40px rgba(212, 175, 55, 0.3); }
            50% { box-shadow: 0 0 60px rgba(212, 175, 55, 0.5); }
        }

        .faction-icon-modern {
            position: absolute;
            width: 70px;
            height: 70px;
            background: rgba(20, 25, 30, 0.9);
            border: 2px solid rgba(212, 175, 55, 0.3);
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            cursor: pointer;
            backdrop-filter: blur(5px);
        }

        .faction-icon-modern:hover {
            border-color: #D4AF37;
            transform: scale(1.2);
            box-shadow: 0 0 30px #D4AF37;
        }

        .faction-icon-modern i {
            font-size: 2rem;
